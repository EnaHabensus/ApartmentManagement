---
import '../styles/global.css';
const error = Astro.url.searchParams.get('error');
---

<!DOCTYPE html>
<html lang="hr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Registracija — Moji Apartmani</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-white overflow-hidden relative flex flex-col">

    <!-- Gradijentni blob pozadina -->
    <div class="fixed inset-0 pointer-events-none overflow-hidden">
      <div class="absolute -top-20 -left-20 w-72 h-72 rounded-full bg-blue-400/20 blur-3xl"></div>
      <div class="absolute top-[-60px] right-[-40px] w-[520px] h-[420px] rounded-full bg-gradient-to-bl from-orange-400/55 via-amber-300/35 to-transparent blur-2xl"></div>
      <div class="absolute bottom-[-40px] left-[-60px] w-[400px] h-[360px] rounded-full bg-gradient-to-tr from-rose-400/40 via-pink-300/20 to-transparent blur-2xl"></div>
      <div class="absolute bottom-0 right-0 w-[420px] h-[380px] rounded-full bg-gradient-to-tl from-violet-500/40 via-purple-400/20 to-transparent blur-2xl"></div>
    </div>

    <!-- Logo — gore lijevo -->
    <div class="relative z-10 p-7">
      <a href="/login" class="inline-flex items-center gap-2.5">
        <div class="h-7 w-7 rounded-lg bg-blue-600 flex items-center justify-center">
          <span class="text-white font-bold text-[11px] tracking-tight">MA</span>
        </div>
        <span class="text-sm font-semibold text-slate-900">Moji Apartmani</span>
      </a>
    </div>

    <!-- Sadržaj — dvije kolone -->
    <div class="relative z-10 flex flex-1 items-center justify-center px-6 pb-10">
      <div class="flex w-full max-w-5xl items-center gap-20">

        <!-- Lijeva kolona — opis aplikacije (skrivena na mobilnom) -->
        <div class="hidden lg:flex flex-col gap-8 flex-1 max-w-sm">
          <div>
            <h2 class="text-2xl font-semibold text-slate-900 tracking-tight leading-snug mb-2">
              Upravljajte apartmanima na jednom mjestu
            </h2>
            <p class="text-slate-500 text-sm leading-relaxed">
              Sve što trebate za uspješno iznajmljivanje — od rezervacija do financija.
            </p>
          </div>

          <div class="space-y-6">
            <div class="flex gap-4">
              <div class="mt-0.5 w-[3px] rounded-full bg-blue-600 self-stretch shrink-0"></div>
              <div>
                <p class="text-sm font-semibold text-slate-900">Rezervacije i kalendar</p>
                <p class="text-sm text-slate-500 mt-0.5">
                  Pratite sve rezervacije, check-in i check-out u preglednom kalendaru.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-0.5 w-[3px] rounded-full bg-blue-600 self-stretch shrink-0"></div>
              <div>
                <p class="text-sm font-semibold text-slate-900">Financijska izvješća</p>
                <p class="text-sm text-slate-500 mt-0.5">
                  Automatski izračun prihoda, provizija i neto zarade po apartmanu i periodu.
                </p>
              </div>
            </div>

            <div class="flex gap-4">
              <div class="mt-0.5 w-[3px] rounded-full bg-blue-600 self-stretch shrink-0"></div>
              <div>
                <p class="text-sm font-semibold text-slate-900">Tim i zadatci</p>
                <p class="text-sm text-slate-500 mt-0.5">
                  Dodijelite zadatke čišćenja osoblju i primajte obavijesti u realnom vremenu.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Desna kolona — forma -->
        <div class="w-full max-w-[420px]">
          <div class="bg-white rounded-2xl shadow-[0_8px_40px_rgba(0,0,0,0.12)] p-8">

            <h1 class="text-[22px] font-semibold text-slate-900 mb-6 tracking-tight">
              Kreirajte račun
            </h1>

            {error && (
              <div class="mb-5 rounded-xl bg-red-50 border border-red-200 px-4 py-3">
                <p class="text-sm text-red-600">
                  {error === 'password_mismatch' && 'Lozinke se ne podudaraju.'}
                  {error === 'email_taken' && 'Ovaj email je već u upotrebi.'}
                  {error === 'weak_password' && 'Lozinka mora imati najmanje 8 znakova.'}
                  {error === 'server_error' && 'Došlo je do greške. Pokušajte ponovno.'}
                  {!['password_mismatch','email_taken','weak_password','server_error'].includes(error) && error}
                </p>
              </div>
            )}

            <form action="/api/auth/register" method="POST" class="space-y-4">
              <div>
                <label for="full_name" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Ime i prezime
                </label>
                <input
                  id="full_name"
                  name="full_name"
                  type="text"
                  autocomplete="name"
                  required
                  class="input"
                  placeholder="Ivan Horvat"
                />
              </div>

              <div>
                <label for="email" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Email adresa
                </label>
                <input
                  id="email"
                  name="email"
                  type="email"
                  autocomplete="email"
                  required
                  class="input"
                  placeholder="vas@email.com"
                />
              </div>

              <div>
                <label for="password" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Lozinka
                </label>
                <input
                  id="password"
                  name="password"
                  type="password"
                  autocomplete="new-password"
                  required
                  minlength="8"
                  class="input"
                  placeholder="Najmanje 8 znakova"
                />
              </div>

              <div>
                <label for="password_confirm" class="block text-sm font-medium text-slate-700 mb-1.5">
                  Potvrda lozinke
                </label>
                <input
                  id="password_confirm"
                  name="password_confirm"
                  type="password"
                  autocomplete="new-password"
                  required
                  class="input"
                  placeholder="Ponovite lozinku"
                />
              </div>

              <button
                type="submit"
                class="mt-1 w-full rounded-lg bg-blue-600 py-2.5 text-sm font-semibold text-white hover:bg-blue-700 transition-colors focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2"
              >
                Kreiraj račun
              </button>
            </form>

            <p class="mt-5 text-center text-sm text-slate-500">
              Već imate račun?{' '}
              <a href="/login" class="text-blue-600 font-semibold hover:text-blue-700">
                Prijavite se
              </a>
            </p>
          </div>
        </div>

      </div>
    </div>
  </body>
</html>
