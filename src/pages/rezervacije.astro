---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';
import type { Reservation, Apartment } from '../lib/types';
import { getReservationStatus, STATUS_LABELS, STATUS_COLORS, PAYMENT_TYPE_LABELS } from '../lib/types';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;
const adminSupabase = createSupabaseAdminClient();

// Dohvati uloge korisnika
const { data: myApartmentUsers } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id, role')
  .eq('user_id', user.id);

const isAdmin = (myApartmentUsers ?? []).some((au) => au.role === 'admin');
const adminApartmentIds = (myApartmentUsers ?? []).filter((au) => au.role === 'admin').map((au) => au.apartment_id);
const allApartmentIds = (myApartmentUsers ?? []).map((au) => au.apartment_id);

// Dohvati apartmane (uključi check_out_time za kreiranje zadatka čišćenja)
const { data: apartmentsData } = await adminSupabase
  .from('apartments')
  .select('id, name, check_out_time, color')
  .in('id', adminApartmentIds.length > 0 ? adminApartmentIds : ['none'])
  .eq('is_deleted', false);

const allApartments = apartmentsData ?? [];
const adminApartments = allApartments.filter((a) => adminApartmentIds.includes(a.id));
const aptCheckOutTimeMap = new Map(allApartments.map((a) => [a.id, (a as any).check_out_time as string | null]));

// URL parametri
const tab = Astro.url.searchParams.get('tab') ?? 'sve';
const filterApartmentId = Astro.url.searchParams.get('apartment_id') ?? '';
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');

// Dohvati rezervacije
const aptIds = filterApartmentId
  ? [filterApartmentId]
  : adminApartmentIds;

let reservationsQuery = adminSupabase
  .from('reservations')
  .select('*')
  .in('apartment_id', aptIds.length > 0 ? aptIds : ['none'])
  .order('check_in', { ascending: true });

// Filter po tabu
if (tab === 'otkazane') {
  reservationsQuery = reservationsQuery.eq('status', 'cancelled');
} else {
  reservationsQuery = reservationsQuery.eq('status', 'active');
}

const { data: rawReservations } = await reservationsQuery;

// Filter po computed statusu (tab)
const TZ = 'Europe/Zagreb';
const todayStr = new Date().toLocaleDateString('sv-SE', { timeZone: TZ });
const today = new Date(todayStr + 'T00:00:00');

let reservations = (rawReservations ?? []).filter((r) => {
  const s = getReservationStatus(r);
  if (tab === 'sve') return true;
  if (tab === 'nadolazece') return s === 'upcoming';
  if (tab === 'u-toku') return s === 'active';
  if (tab === 'zavrsene') return s === 'completed';
  if (tab === 'otkazane') return s === 'cancelled';
  return true;
});

// Sortiraj sve uzlazno po check_in (najraniji prvi)
reservations = reservations.sort((a, b) => a.check_in.localeCompare(b.check_in));

// KPI — dohvati sve rezervacije za statistiku (neovisno o tabu)
const { data: allReservations } = await adminSupabase
  .from('reservations')
  .select('status, check_in, check_out')
  .in('apartment_id', aptIds.length > 0 ? aptIds : ['none']);

const kpi = {
  sve: (allReservations ?? []).length,
  uToku: (allReservations ?? []).filter((r) => getReservationStatus(r) === 'active').length,
  nadolazece: (allReservations ?? []).filter((r) => getReservationStatus(r) === 'upcoming').length,
  zavrsene: (allReservations ?? []).filter((r) => getReservationStatus(r) === 'completed').length,
  otkazane: (allReservations ?? []).filter((r) => r.status === 'cancelled').length,
};

// Dohvati nazive apartmana za prikaz
const aptMap = new Map(allApartments.map((a) => [a.id, a.name]));
const aptColorMap = new Map(allApartments.map((a) => [a.id, (a as any).color as string ?? '#3B82F6']));

// Dohvati dodjele čišćenja za prikazane rezervacije
const reservationIds = reservations.map((r) => r.id);
const { data: cleaningRows } = reservationIds.length > 0
  ? await adminSupabase.from('reservation_cleaning').select('reservation_id, user_id, external_member_id').in('reservation_id', reservationIds)
  : { data: [] };

const cleaningUserIds = [...new Set((cleaningRows ?? []).filter((c) => c.user_id).map((c) => c.user_id as string))];
const { data: cleaningProfiles } = cleaningUserIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name').in('id', cleaningUserIds)
  : { data: [] };
const cleaningProfileMap = new Map((cleaningProfiles ?? []).map((p) => [p.id, p.full_name]));

const cleaningExtIds = [...new Set((cleaningRows ?? []).filter((c) => c.external_member_id).map((c) => c.external_member_id as string))];
const { data: cleaningExtMembers } = cleaningExtIds.length > 0
  ? await adminSupabase.from('external_members').select('id, name').in('id', cleaningExtIds)
  : { data: [] };
const cleaningExtMap = new Map((cleaningExtMembers ?? []).map((em) => [em.id, em.name]));

// reservation_id -> [{ id, type, full_name }] — regularne i vanjske osobe
const cleaningMap = new Map<string, Array<{ id: string; type: 'user' | 'external'; full_name: string }>>();
for (const c of (cleaningRows ?? [])) {
  if (!cleaningMap.has(c.reservation_id)) cleaningMap.set(c.reservation_id, []);
  if (c.user_id) {
    const name = cleaningProfileMap.get(c.user_id) ?? '?';
    cleaningMap.get(c.reservation_id)!.push({ id: c.user_id, type: 'user', full_name: name });
  } else if (c.external_member_id) {
    const name = cleaningExtMap.get(c.external_member_id) ?? '?';
    cleaningMap.get(c.reservation_id)!.push({ id: c.external_member_id, type: 'external', full_name: name });
  }
}

// Dohvati korisnike po apartmanu za dropdown čišćenja
const { data: allAptUsers } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id, user_id')
  .in('apartment_id', allApartmentIds.length > 0 ? allApartmentIds : ['none']);
const aptUserIds = [...new Set((allAptUsers ?? []).map((u) => u.user_id))];
const { data: aptUserProfiles } = aptUserIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name').in('id', aptUserIds)
  : { data: [] };
const aptUserProfileMap = new Map((aptUserProfiles ?? []).map((p) => [p.id, p.full_name]));
// apartment_id -> [{ user_id, full_name }]
const aptUsersForCleaningMap: Record<string, Array<{ user_id: string; full_name: string }>> = {};
for (const au of (allAptUsers ?? [])) {
  if (!aptUsersForCleaningMap[au.apartment_id]) aptUsersForCleaningMap[au.apartment_id] = [];
  aptUsersForCleaningMap[au.apartment_id].push({ user_id: au.user_id, full_name: aptUserProfileMap.get(au.user_id) ?? '?' });
}

// Dohvati pomoćno osoblje po apartmanu za dropdown čišćenja
const { data: allAptExtRows } = await adminSupabase
  .from('apartment_external_members')
  .select('apartment_id, external_member_id')
  .in('apartment_id', allApartmentIds.length > 0 ? allApartmentIds : ['none']);
const allExtMemberIds = [...new Set((allAptExtRows ?? []).map((r) => r.external_member_id))];
const { data: allExtMemberData } = allExtMemberIds.length > 0
  ? await adminSupabase.from('external_members').select('id, name').in('id', allExtMemberIds)
  : { data: [] };
const allExtMemberMap = new Map((allExtMemberData ?? []).map((em) => [em.id, em]));
// apartment_id -> [{ id, name }]
const aptExtMembersForCleaningMap: Record<string, Array<{ id: string; name: string }>> = {};
for (const row of (allAptExtRows ?? [])) {
  const em = allExtMemberMap.get(row.external_member_id);
  if (!em) continue;
  if (!aptExtMembersForCleaningMap[row.apartment_id]) aptExtMembersForCleaningMap[row.apartment_id] = [];
  aptExtMembersForCleaningMap[row.apartment_id].push({ id: em.id, name: em.name });
}

function formatDate(d: string): string {
  const [y, m, day] = d.split('-');
  return `${day}.${m}.${y}`;
}

function formatCurrency(n: number | null): string {
  if (n === null || n === undefined) return '—';
  return new Intl.NumberFormat('hr-HR', { style: 'currency', currency: 'EUR' }).format(n);
}

function calcNocenja(check_in: string, check_out: string): number {
  return Math.round((new Date(check_out).getTime() - new Date(check_in).getTime()) / (1000 * 60 * 60 * 24));
}

const tabs = [
  { key: 'sve', label: 'Sve' },
  { key: 'u-toku', label: 'U toku' },
  { key: 'nadolazece', label: 'Nadolazeće' },
  { key: 'zavrsene', label: 'Završene' },
  { key: 'otkazane', label: 'Otkazane' },
];
---

<AppLayout title="Rezervacije" user={profile} isAdmin={true} activeRoute="/rezervacije">
  <div class="p-4 md:p-6 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-gray-900">Rezervacije</h1>
        <p class="text-gray-500 text-sm mt-0.5">{reservations.length} rezervacij{reservations.length === 1 ? 'a' : reservations.length < 5 ? 'e' : 'a'}</p>
      </div>
      {isAdmin && (
        <button onclick="openAddModal()" class="btn-primary text-sm px-3 py-2">
          + Dodaj
        </button>
      )}
    </div>


    <!-- KPI kartice -->
    <div class="-mx-4 px-4 md:mx-0 md:px-0 mb-6">
      <div class="flex overflow-x-auto gap-3 py-1 snap-x snap-mandatory md:grid md:grid-cols-5 md:gap-4 md:overflow-visible md:py-0">
        <a href={`/rezervacije?tab=sve${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
          class={`card px-4 py-5 md:p-4 hover:shadow-md transition-shadow flex-shrink-0 w-44 md:w-auto snap-start ${tab === 'sve' ? 'ring-2 ring-blue-500' : ''}`}>
          <p class="text-xs font-medium text-gray-500 mb-1.5">Ukupno</p>
          <p class="text-2xl md:text-xl font-bold text-gray-900">{kpi.sve}</p>
        </a>
        <a href={`/rezervacije?tab=u-toku${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
          class={`card px-4 py-5 md:p-4 hover:shadow-md transition-shadow flex-shrink-0 w-44 md:w-auto snap-start ${tab === 'u-toku' ? 'ring-2 ring-blue-500' : ''}`}>
          <p class="text-xs font-medium text-gray-500 mb-1.5">U toku</p>
          <p class="text-2xl md:text-xl font-bold text-gray-900">{kpi.uToku}</p>
        </a>
        <a href={`/rezervacije?tab=nadolazece${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
          class={`card px-4 py-5 md:p-4 hover:shadow-md transition-shadow flex-shrink-0 w-44 md:w-auto snap-start ${tab === 'nadolazece' ? 'ring-2 ring-blue-500' : ''}`}>
          <p class="text-xs font-medium text-gray-500 mb-1.5">Nadolazeće</p>
          <p class="text-2xl md:text-xl font-bold text-gray-900">{kpi.nadolazece}</p>
        </a>
        <a href={`/rezervacije?tab=zavrsene${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
          class={`card px-4 py-5 md:p-4 hover:shadow-md transition-shadow flex-shrink-0 w-44 md:w-auto snap-start ${tab === 'zavrsene' ? 'ring-2 ring-blue-500' : ''}`}>
          <p class="text-xs font-medium text-gray-500 mb-1.5">Završene</p>
          <p class="text-2xl md:text-xl font-bold text-gray-900">{kpi.zavrsene}</p>
        </a>
        <a href={`/rezervacije?tab=otkazane${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
          class={`card px-4 py-5 md:p-4 hover:shadow-md transition-shadow flex-shrink-0 w-44 md:w-auto snap-start ${tab === 'otkazane' ? 'ring-2 ring-blue-500' : ''}`}>
          <p class="text-xs font-medium text-gray-500 mb-1.5">Otkazane</p>
          <p class="text-2xl md:text-xl font-bold text-gray-900">{kpi.otkazane}</p>
        </a>
      </div>
    </div>

    <!-- Filteri i tabovi -->
    <div class="mb-4 space-y-2 md:space-y-0 md:flex md:items-center md:justify-between md:gap-3">

      <!-- Tabovi: select na mobilnom, pills na desktopu -->
      <div>
        <!-- Mobile: dropdown select -->
        <select
          class="input w-full md:hidden"
          onchange="window.location.href=this.value"
        >
          {tabs.map((t) => (
            <option
              value={`/rezervacije?tab=${t.key}${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
              selected={tab === t.key}
            >
              {t.label}
            </option>
          ))}
        </select>

        <!-- Desktop: pills -->
        <div class="hidden md:flex gap-1 bg-gray-100 rounded-lg p-1">
          {tabs.map((t) => (
            <a
              href={`/rezervacije?tab=${t.key}${filterApartmentId ? `&apartment_id=${filterApartmentId}` : ''}`}
              class={`px-3 py-1.5 rounded-md text-sm font-medium transition-colors ${
                tab === t.key
                  ? 'bg-white text-gray-900 shadow-sm'
                  : 'text-gray-500 hover:text-gray-700'
              }`}
            >
              {t.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Filter apartman -->
      <form method="GET" action="/rezervacije" id="filter-form">
        <input type="hidden" name="tab" value={tab} />
        <select
          name="apartment_id"
          onchange="document.getElementById('filter-form').submit()"
          class="input w-full md:w-auto"
        >
          <option value="">Svi apartmani</option>
          {allApartments.map((apt) => (
            <option value={apt.id} selected={filterApartmentId === apt.id}>{apt.name}</option>
          ))}
        </select>
      </form>
    </div>

    <!-- Tablica -->
    {reservations.length === 0 ? (
      <div class="card p-12 text-center">
        <div class="text-gray-400 mb-4">
          <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
              d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Nema rezervacija</h3>
        <p class="text-gray-500">Nema rezervacija u ovoj kategoriji.</p>
      </div>
    ) : (
      <>
        {/* ── Mobile: kartice ── */}
        <div class="md:hidden space-y-3">
          {reservations.map((r) => {
            const neto = (r.amount_gross ?? 0) - (r.commission ?? 0);
            const computedStatus = getReservationStatus(r);
            const cleaners = cleaningMap.get(r.id) ?? [];
            const aptColor = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
            const aptName = aptMap.get(r.apartment_id) ?? '—';
            const nocenja = calcNocenja(r.check_in, r.check_out);
            const rezData = JSON.stringify({
              id: r.id, apartment_id: r.apartment_id,
              guest_name: r.guest_name, guest_phone: r.guest_phone ?? '',
              check_in: r.check_in, check_out: r.check_out,
              num_guests: r.num_guests, payment_type: r.payment_type ?? '',
              amount_gross: r.amount_gross ?? 0, commission: r.commission ?? 0,
              neto, nocenja,
              documents_received: !!r.documents_received,
              guests_registered: !!r.guests_registered,
              is_paid: !!r.is_paid,
              status: r.status, computed_status: computedStatus,
              apt_name: aptName, apt_color: aptColor,
            });
            return (
              <div
                class="card p-4 cursor-pointer active:bg-slate-50 transition-colors"
                id={`mobile-card-${r.id}`}
                data-rez={rezData}
                onclick="openRezDrawer(this)"
              >
                {/* Redak 1: apartman + status */}
                <div class="flex items-center justify-between gap-2 mb-1.5">
                  <span
                    class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium whitespace-nowrap"
                    style={`background-color:${aptColor}20;color:${aptColor};box-shadow:inset 0 0 0 1px ${aptColor}40`}
                  >{aptName}</span>
                  <span class={`badge ${STATUS_COLORS[computedStatus]} flex-shrink-0`}>
                    {r.status === 'cancelled' ? 'Otkazana' : STATUS_LABELS[computedStatus]}
                  </span>
                </div>
                {/* Redak 2: ime gosta */}
                <p class="font-semibold text-slate-900 truncate mb-1.5">{r.guest_name}</p>
                {/* Redak 3: datumi + noćenja */}
                <div class="flex items-center gap-2 mb-2">
                  <span class="text-sm text-slate-600 whitespace-nowrap">{formatDate(r.check_in)} → {formatDate(r.check_out)}</span>
                  <span class="text-xs text-slate-400 whitespace-nowrap">{nocenja === 1 ? '1 noć' : `${nocenja} noćenja`}</span>
                </div>
                {/* Redak 4: detalji link */}
                <div class="flex items-center gap-0.5 text-blue-600 justify-end">
                  <span class="text-xs font-medium">Detalji</span>
                  <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                </div>
              </div>
            );
          })}
        </div>

        {/* ── Desktop: tablica ── */}
        <div class="hidden md:block overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
          <table class="text-sm" style="min-width: 1200px; width: 100%;">
            <thead>
            <tr>
              <th class="table-head px-4 py-3 text-left">Gost</th>
              <th class="table-head px-4 py-3 text-left">Status</th>
              <th class="table-head px-4 py-3 text-left">Apartman</th>
              <th class="table-head px-4 py-3 text-left whitespace-nowrap">Check-in</th>
              <th class="table-head px-4 py-3 text-left whitespace-nowrap">Check-out</th>
              <th class="table-head px-4 py-3 text-center whitespace-nowrap">Noćenja</th>
              <th class="table-head px-4 py-3 text-left">Gosti</th>
              <th class="table-head px-4 py-3 text-left">Plaćanje</th>
              <th class="table-head px-4 py-3 text-right">Bruto</th>
              <th class="table-head px-4 py-3 text-right">Provizija</th>
              <th class="table-head px-4 py-3 text-right">Neto</th>
              <th class="table-head px-4 py-3 text-center whitespace-nowrap">Dokumenti</th>
              <th class="table-head px-4 py-3 text-center">Prijava</th>
              <th class="table-head px-4 py-3 text-center">Plaćeno</th>
              <th class="table-head px-4 py-3 text-left whitespace-nowrap">Čišćenje</th>
              {isAdmin && <th class="table-head px-4 py-3"></th>}
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {reservations.map((r) => {
              const neto = (r.amount_gross ?? 0) - (r.commission ?? 0);
              const computedStatus = getReservationStatus(r);
              const nocenja = calcNocenja(r.check_in, r.check_out);
              const cleaners = cleaningMap.get(r.id) ?? [];
              const aptUsers = aptUsersForCleaningMap[r.apartment_id] ?? [];
              return (
                <tr class="table-row" id={`row-${r.id}`}>
                  <td class="table-cell font-medium text-gray-900 whitespace-nowrap">
                    <div>{r.guest_name}</div>
                    {r.guest_phone && <div class="text-xs text-gray-400">{r.guest_phone}</div>}
                  </td>
                  <td class="table-cell">
                    <span class={`badge ${STATUS_COLORS[computedStatus]}`}>
                      {r.status === 'cancelled' ? 'Otkazana' : STATUS_LABELS[computedStatus]}
                    </span>
                  </td>
                  <td class="table-cell">
                    {(() => {
                      const color = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
                      return (
                        <span
                          class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium whitespace-nowrap"
                          style={`background-color: ${color}20; color: ${color}; box-shadow: inset 0 0 0 1px ${color}40`}
                        >
                          {aptMap.get(r.apartment_id) ?? '—'}
                        </span>
                      );
                    })()}
                  </td>
                  <td class="table-cell text-gray-700 whitespace-nowrap">{formatDate(r.check_in)}</td>
                  <td class="table-cell text-gray-700 whitespace-nowrap">{formatDate(r.check_out)}</td>
                  <td class="table-cell text-center text-gray-700 font-medium">{nocenja}</td>
                  <td class="table-cell text-gray-500 text-center">{r.num_guests}</td>
                  <td class="table-cell text-gray-500">
                    {r.payment_type ? PAYMENT_TYPE_LABELS[r.payment_type] : '—'}
                  </td>
                  <td class="table-cell text-right text-gray-700">{formatCurrency(r.amount_gross)}</td>
                  <td class="table-cell text-right text-gray-500">{formatCurrency(r.commission)}</td>
                  <td class="table-cell text-right font-medium text-gray-900">{formatCurrency(neto > 0 ? neto : null)}</td>
                  <td class="table-cell text-center">
                    <button
                      data-field="documents_received"
                      onclick={`toggleField('${r.id}', 'documents_received', ${r.documents_received})`}
                      class={`h-6 w-6 rounded-full border-2 flex items-center justify-center mx-auto transition-colors ${
                        r.documents_received
                          ? 'bg-green-500 border-green-500 text-white'
                          : 'border-gray-300 text-transparent hover:border-gray-400'
                      }`}
                      title={r.documents_received ? 'Dokumenti primljeni' : 'Dokumenti nisu primljeni'}
                    >
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </button>
                  </td>
                  <td class="table-cell text-center">
                    <button
                      data-field="guests_registered"
                      onclick={`toggleField('${r.id}', 'guests_registered', ${r.guests_registered})`}
                      class={`h-6 w-6 rounded-full border-2 flex items-center justify-center mx-auto transition-colors ${
                        r.guests_registered
                          ? 'bg-green-500 border-green-500 text-white'
                          : 'border-gray-300 text-transparent hover:border-gray-400'
                      }`}
                      title={r.guests_registered ? 'Gosti prijavljeni' : 'Gosti nisu prijavljeni'}
                    >
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </button>
                  </td>
                  <td class="table-cell text-center">
                    <button
                      data-field="is_paid"
                      onclick={`toggleField('${r.id}', 'is_paid', ${r.is_paid})`}
                      class={`h-6 w-6 rounded-full border-2 flex items-center justify-center mx-auto transition-colors ${
                        r.is_paid
                          ? 'bg-green-500 border-green-500 text-white'
                          : 'border-gray-300 text-transparent hover:border-gray-400'
                      }`}
                      title={r.is_paid ? 'Plaćeno' : 'Nije plaćeno'}
                    >
                      <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                      </svg>
                    </button>
                  </td>
                  <td class="table-cell">
                    {(() => {
                      const aptExtMembers = aptExtMembersForCleaningMap[r.apartment_id] ?? [];
                      const hasAnyone = aptUsers.length > 0 || aptExtMembers.length > 0;
                      return hasAnyone ? (
                        <div class="relative" id={`cleaning-wrap-${r.id}`}>
                          <button
                            type="button"
                            onclick={`toggleCleaningDropdown('${r.id}')`}
                            class="flex items-center gap-1 rounded-md border border-slate-300 bg-white px-2 py-1 text-xs text-slate-700 hover:bg-slate-50 max-w-[150px]"
                          >
                            {cleaners.length === 0 ? (
                              <span class="text-slate-400">— Odaberi —</span>
                            ) : (
                              <span class="truncate">
                                {cleaners.map((c) => c.full_name.split(' ')[0]).join(', ')}
                              </span>
                            )}
                            <svg class="h-3 w-3 shrink-0 text-slate-400 ml-1" viewBox="0 0 20 20" fill="currentColor"><path fill-rule="evenodd" d="M5.22 8.22a.75.75 0 0 1 1.06 0L10 11.94l3.72-3.72a.75.75 0 1 1 1.06 1.06l-4.25 4.25a.75.75 0 0 1-1.06 0L5.22 9.28a.75.75 0 0 1 0-1.06Z" clip-rule="evenodd"/></svg>
                          </button>
                          <div
                            id={`cleaning-dd-${r.id}`}
                            class="hidden absolute z-30 left-0 top-full mt-1 w-56 rounded-xl border border-slate-200 bg-white shadow-lg p-2"
                          >
                            <div class="space-y-0.5 max-h-52 overflow-y-auto">
                              {aptUsers.map((u) => (
                                <label class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-50 cursor-pointer">
                                  <input
                                    type="checkbox"
                                    class="h-3.5 w-3.5 rounded border-slate-300 text-blue-600 cleaning-cb"
                                    data-res={r.id}
                                    data-type="user"
                                    value={u.user_id}
                                    checked={cleaners.some((c) => c.type === 'user' && c.id === u.user_id)}
                                  />
                                  <span class="text-xs text-slate-700">{u.full_name}</span>
                                </label>
                              ))}
                              {aptExtMembers.length > 0 && aptUsers.length > 0 && (
                                <div class="border-t border-slate-100 my-1"></div>
                              )}
                              {aptExtMembers.map((em) => (
                                <label class="flex items-center gap-2 px-2 py-1.5 rounded-lg hover:bg-slate-50 cursor-pointer">
                                  <input
                                    type="checkbox"
                                    class="h-3.5 w-3.5 rounded border-slate-300 text-purple-600 cleaning-cb"
                                    data-res={r.id}
                                    data-type="external"
                                    value={em.id}
                                    checked={cleaners.some((c) => c.type === 'external' && c.id === em.id)}
                                  />
                                  <span class="text-xs text-slate-700">{em.name} <span class="text-purple-600">(Pomoćno)</span></span>
                                </label>
                              ))}
                            </div>
                            <div class="border-t border-slate-100 mt-2 pt-2 flex gap-1.5">
                              <button
                                type="button"
                                onclick={`saveCleaningAssignees('${r.id}', '${r.check_out}')`}
                                class="flex-1 rounded-md bg-blue-600 px-2 py-1 text-xs font-semibold text-white hover:bg-blue-700"
                              >
                                Spremi
                              </button>
                              <button
                                type="button"
                                onclick={`toggleCleaningDropdown('${r.id}')`}
                                class="rounded-md border border-slate-300 px-2 py-1 text-xs text-slate-600 hover:bg-slate-50"
                              >
                                Zatvori
                              </button>
                            </div>
                          </div>
                        </div>
                      ) : (
                        <span class="text-slate-400 text-xs">—</span>
                      );
                    })()}
                  </td>
                  {isAdmin && (
                    <td class="table-cell">
                      <div class="flex items-center gap-1">
                        <button
                          onclick={`openEditModal(${JSON.stringify({
                            id: r.id,
                            apartment_id: r.apartment_id,
                            guest_name: r.guest_name,
                            guest_phone: r.guest_phone ?? '',
                            check_in: r.check_in,
                            check_out: r.check_out,
                            num_guests: r.num_guests,
                            payment_type: r.payment_type ?? '',
                            amount_gross: r.amount_gross ?? '',
                            commission: r.commission ?? '',
                          })})`}
                          class="btn-ghost text-xs px-2 py-1"
                        >
                          Uredi
                        </button>
                        {r.status === 'active' && (
                          <button
                            onclick={`confirmCancel('${r.id}', '${r.guest_name.replace(/'/g, "\\'")}')`}
                            class="btn-ghost text-xs px-2 py-1 text-red-500 hover:bg-red-50 hover:text-red-700"
                          >
                            Otkaži
                          </button>
                        )}
                      </div>
                    </td>
                  )}
                </tr>
              );
            })}
          </tbody>
        </table>
        </div>
      </>
    )}
  </div>

  {/* ── Modali (samo admin) ── */}
  {isAdmin && (
    <>
      {/* Modal: Dodaj rezervaciju */}
      <div id="modal-add" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-add')">
        <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
          <div class="p-6 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900">Dodaj rezervaciju</h2>
          </div>
          <form id="form-add" class="p-6 space-y-4">
            <div id="add-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-3">
              <p class="text-sm text-red-600" id="add-error-text"></p>
            </div>
            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2">
                <label class="label">Gost (ime i prezime) *</label>
                <input name="guest_name" type="text" required class="input" placeholder="npr. Ivan Horvat" />
              </div>
              <div class="col-span-2">
                <label class="label">Broj telefona</label>
                <input name="guest_phone" type="tel" class="input" placeholder="+385..." />
              </div>
              <div class="col-span-2">
                <label class="label">Apartman *</label>
                <select name="apartment_id" required class="input">
                  <option value="">Odaberi apartman...</option>
                  {adminApartments.map((apt) => (
                    <option value={apt.id}>{apt.name}</option>
                  ))}
                </select>
              </div>
              <div>
                <label class="label">Check-in *</label>
                <input name="check_in" type="date" required class="input" />
              </div>
              <div>
                <label class="label">Check-out *</label>
                <input name="check_out" type="date" required class="input" />
              </div>
              <div>
                <label class="label">Broj gostiju *</label>
                <input name="num_guests" type="number" min="1" required class="input" value="1" />
              </div>
              <div>
                <label class="label">Način plaćanja</label>
                <select name="payment_type" class="input">
                  <option value="">—</option>
                  <option value="credit_card">Kartica</option>
                  <option value="cash">Gotovina</option>
                  <option value="bank_transfer">Bankovni prijenos</option>
                  <option value="airbnb">Airbnb</option>
                  <option value="booking_com">Booking.com</option>
                </select>
              </div>
              <div>
                <label class="label">Bruto iznos (EUR)</label>
                <input name="amount_gross" type="number" min="0" step="0.01" class="input" placeholder="0.00" />
              </div>
              <div>
                <label class="label">Provizija (EUR)</label>
                <input name="commission" type="number" min="0" step="0.01" class="input" placeholder="0.00" />
              </div>
            </div>
            <div class="flex justify-end gap-3 pt-2">
              <button type="button" onclick="document.getElementById('modal-add').classList.add('hidden')" class="btn-secondary">
                Odustani
              </button>
              <button type="submit" id="add-submit" class="btn-primary">Spremi</button>
            </div>
          </form>
        </div>
      </div>

      {/* Modal: Uredi rezervaciju */}
      <div id="modal-edit" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-edit')">
        <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
          <div class="p-6 border-b border-gray-100">
            <h2 class="text-lg font-semibold text-gray-900">Uredi rezervaciju</h2>
          </div>
          <form id="form-edit" class="p-6 space-y-4">
            <div id="edit-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-3">
              <p class="text-sm text-red-600" id="edit-error-text"></p>
            </div>
            <input type="hidden" name="id" id="edit-id" />
            <div class="grid grid-cols-2 gap-4">
              <div class="col-span-2">
                <label class="label">Gost (ime i prezime) *</label>
                <input id="edit-guest_name" name="guest_name" type="text" required class="input" />
              </div>
              <div class="col-span-2">
                <label class="label">Broj telefona</label>
                <input id="edit-guest_phone" name="guest_phone" type="tel" class="input" />
              </div>
              <div class="col-span-2">
                <label class="label">Apartman *</label>
                <select id="edit-apartment_id" name="apartment_id" required class="input">
                  <option value="">Odaberi apartman...</option>
                  {adminApartments.map((apt) => (
                    <option value={apt.id}>{apt.name}</option>
                  ))}
                </select>
              </div>
              <div>
                <label class="label">Check-in *</label>
                <input id="edit-check_in" name="check_in" type="date" required class="input" />
              </div>
              <div>
                <label class="label">Check-out *</label>
                <input id="edit-check_out" name="check_out" type="date" required class="input" />
              </div>
              <div>
                <label class="label">Broj gostiju *</label>
                <input id="edit-num_guests" name="num_guests" type="number" min="1" required class="input" />
              </div>
              <div>
                <label class="label">Način plaćanja</label>
                <select id="edit-payment_type" name="payment_type" class="input">
                  <option value="">—</option>
                  <option value="credit_card">Kartica</option>
                  <option value="cash">Gotovina</option>
                  <option value="bank_transfer">Bankovni prijenos</option>
                  <option value="airbnb">Airbnb</option>
                  <option value="booking_com">Booking.com</option>
                </select>
              </div>
              <div>
                <label class="label">Bruto iznos (EUR)</label>
                <input id="edit-amount_gross" name="amount_gross" type="number" min="0" step="0.01" class="input" />
              </div>
              <div>
                <label class="label">Provizija (EUR)</label>
                <input id="edit-commission" name="commission" type="number" min="0" step="0.01" class="input" />
              </div>
            </div>
            <div class="flex items-center justify-between pt-2">
              <button
                type="button"
                onclick="confirmDeleteRez(document.getElementById('edit-id').value, document.getElementById('edit-guest_name').value)"
                class="btn-danger"
              >
                Obriši rezervaciju
              </button>
              <div class="flex gap-3">
                <button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="btn-secondary">
                  Odustani
                </button>
                <button type="submit" id="edit-submit" class="btn-primary">Spremi promjene</button>
              </div>
            </div>
          </form>
        </div>
      </div>

      {/* Modal: Potvrda otkazivanja */}
      <div id="modal-cancel" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-cancel')">
        <div class="modal-content p-6" onclick="event.stopPropagation()">
          <h2 class="text-lg font-semibold text-gray-900 mb-2">Otkaži rezervaciju</h2>
          <p class="text-gray-600 mb-6">
            Jeste li sigurni da želite otkazati rezervaciju za gosta <strong id="cancel-name"></strong>?
          </p>
          <form action="/api/rezervacije/cancel" method="POST">
            <input type="hidden" name="id" id="cancel-id" />
            <div class="flex justify-end gap-3">
              <button type="button" onclick="document.getElementById('modal-cancel').classList.add('hidden')" class="btn-secondary">
                Odustani
              </button>
              <button type="submit" class="btn-danger">Otkaži rezervaciju</button>
            </div>
          </form>
        </div>
      </div>

      {/* Modal: Potvrda brisanja */}
      <div id="modal-delete-rez" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-delete-rez')">
        <div class="modal-content p-6" onclick="event.stopPropagation()">
          <h2 class="text-lg font-semibold text-gray-900 mb-2">Obriši rezervaciju</h2>
          <p class="text-gray-600 mb-1">
            Jeste li sigurni da želite trajno obrisati rezervaciju za gosta <strong id="delete-rez-name"></strong>?
          </p>
          <p class="text-sm text-red-600 mb-6">Ova akcija se ne može poništiti.</p>
          <input type="hidden" id="delete-rez-id" />
          <div class="flex justify-end gap-3">
            <button type="button" onclick="document.getElementById('modal-delete-rez').classList.add('hidden')" class="btn-secondary">
              Odustani
            </button>
            <button type="button" onclick="doDeleteRez()" class="btn-danger">Obriši</button>
          </div>
        </div>
      </div>
    </>
  )}

  {/* Bottom drawer — mobile only */}
  <div
    id="rez-drawer"
    class="fixed inset-x-0 bottom-0 z-50 bg-white rounded-t-2xl shadow-2xl translate-y-full transition-transform duration-300 ease-out md:hidden flex flex-col"
    style="max-height: 90dvh;"
  >
    <div class="flex-shrink-0 relative flex items-center justify-center px-4 pt-3 pb-3 border-b border-slate-100">
      <div class="w-10 h-1 rounded-full bg-slate-200"></div>
      <button
        onclick="closeRezDrawer()"
        class="absolute right-3 p-1.5 rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <div id="rez-drawer-body" class="flex-1 overflow-y-auto px-4 pt-4 pb-10"></div>
  </div>
  <div id="rez-drawer-overlay" class="hidden fixed inset-0 z-40 bg-black/40 md:hidden" onclick="closeRezDrawer()"></div>

  {/* Toast */}
  <div id="toast" class="hidden fixed bottom-4 right-4 z-[60] rounded-lg px-4 py-3 text-sm font-medium shadow-lg"></div>
</AppLayout>

<script define:vars={{
  _aptUsersInit: aptUsersForCleaningMap,
  _aptExtMembersInit: aptExtMembersForCleaningMap,
  _cleaningDataInit: Object.fromEntries([...cleaningMap.entries()]),
  _isAdminInit: isAdmin,
}}>
  // define:vars je plain JS, bez TypeScript sintakse
  window._aptUsers      = _aptUsersInit;
  window._aptExtMembers = _aptExtMembersInit;
  window._cleaningData  = _cleaningDataInit;
  window._isAdmin       = _isAdminInit;
</script>

<script>
  // ── Drawer ────────────────────────────────────────────────────────────────

  let _drawerRezId: string | null = null;

  const STATUS_LABEL_MAP: Record<string, string> = {
    active: 'U toku', upcoming: 'Nadolazeće', completed: 'Završeno', cancelled: 'Otkazana',
  };
  const STATUS_CLASS_MAP: Record<string, string> = {
    active: 'badge-green', upcoming: 'badge-blue', completed: 'badge-gray', cancelled: 'badge-red',
  };
  const PAYMENT_LABEL_MAP: Record<string, string> = {
    credit_card: 'Kartica', cash: 'Gotovina', bank_transfer: 'Bankovni prijenos',
    airbnb: 'Airbnb', booking_com: 'Booking.com',
  };

  function escHtml(s: any): string {
    return String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
  function fmtDate(d: string): string {
    const [y, m, day] = d.split('-'); return `${day}.${m}.${y}`;
  }
  function fmtCurr(n: number): string {
    if (!n) return '—';
    return new Intl.NumberFormat('hr-HR', { style: 'currency', currency: 'EUR' }).format(n);
  }
  function toggleBtnHtml(rezId: string, field: string, val: boolean): string {
    const on  = 'bg-green-500 border-green-500 text-white';
    const off = 'border-slate-200 text-transparent';
    return `<button data-field="${field}" onclick="toggleField('${rezId}','${field}',${val})"
      class="h-7 w-7 rounded-full border-2 flex items-center justify-center transition-colors flex-shrink-0 ${val ? on : off}">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/></svg>
    </button>`;
  }

  function renderDrawerContent(r: any): string {
    const cleaners: any[]  = (window as any)._cleaningData?.[r.id] ?? [];
    const aptUsers: any[]  = (window as any)._aptUsers?.[r.apartment_id] ?? [];
    const aptExt: any[]    = (window as any)._aptExtMembers?.[r.apartment_id] ?? [];
    const isAdm: boolean   = (window as any)._isAdmin ?? false;

    const statusLabel = r.status === 'cancelled' ? 'Otkazana' : (STATUS_LABEL_MAP[r.computed_status] ?? r.computed_status);
    const statusClass = STATUS_CLASS_MAP[r.computed_status] ?? 'badge-gray';
    const payLabel    = r.payment_type ? (PAYMENT_LABEL_MAP[r.payment_type] ?? r.payment_type) : '—';
    const aptColor    = r.apt_color ?? '#3B82F6';

    // Čišćenje checkboxes
    let cleaningHtml = '';
    if (aptUsers.length > 0 || aptExt.length > 0) {
      const rows = [
        ...aptUsers.map((u: any) => {
          const checked = cleaners.some((c: any) => c.type === 'user' && c.id === u.user_id) ? 'checked' : '';
          return `<label class="flex items-center gap-3 py-3 border-b border-slate-50 cursor-pointer">
            <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-blue-600 cleaning-cb" data-res="${r.id}" data-type="user" value="${u.user_id}" ${checked}>
            <span class="text-sm text-slate-700">${escHtml(u.full_name)}</span>
          </label>`;
        }),
        ...aptExt.map((em: any) => {
          const checked = cleaners.some((c: any) => c.type === 'external' && c.id === em.id) ? 'checked' : '';
          return `<label class="flex items-center gap-3 py-3 border-b border-slate-50 cursor-pointer">
            <input type="checkbox" class="h-4 w-4 rounded border-slate-300 text-purple-600 cleaning-cb" data-res="${r.id}" data-type="external" value="${em.id}" ${checked}>
            <span class="text-sm text-slate-700">${escHtml(em.name)} <span class="text-xs text-purple-500">(Pomoćno)</span></span>
          </label>`;
        }),
      ].join('');
      cleaningHtml = `
        <div class="mt-5">
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-1">Čišćenje</p>
          ${rows}
          <button onclick="saveCleaningAssignees('${r.id}','${r.check_out}')"
            class="mt-3 w-full rounded-xl bg-blue-600 py-3 text-sm font-semibold text-white">
            Spremi čišćenje
          </button>
        </div>`;
    }

    // Akcije
    let actionsHtml = '';
    if (isAdm) {
      const editJson = escHtml(JSON.stringify({
        id: r.id, apartment_id: r.apartment_id, guest_name: r.guest_name,
        guest_phone: r.guest_phone, check_in: r.check_in, check_out: r.check_out,
        num_guests: r.num_guests, payment_type: r.payment_type,
        amount_gross: r.amount_gross, commission: r.commission,
      }));
      const cancelBtn = r.status === 'active'
        ? `<button data-cancel-id="${r.id}" data-cancel-name="${escHtml(r.guest_name)}" onclick="cancelFromDrawer(this)" class="flex-1 btn-secondary text-sm text-red-600 hover:bg-red-50">Otkaži</button>`
        : '';
      actionsHtml = `
        <div class="mt-5 flex gap-2">
          <button data-edit-rez="${editJson}" onclick="editFromDrawer(this)" class="flex-1 btn-secondary text-sm">Uredi</button>
          ${cancelBtn}
        </div>`;
    }

    return `
      <div class="flex items-start justify-between gap-2 mb-1">
        <div>
          <h3 class="text-lg font-bold text-slate-900">${escHtml(r.guest_name)}</h3>
          ${r.guest_phone ? `<p class="text-sm text-slate-500">${escHtml(r.guest_phone)}</p>` : ''}
        </div>
        <span class="badge ${statusClass} flex-shrink-0">${statusLabel}</span>
      </div>

      <div class="flex items-center gap-2 flex-wrap mb-4">
        <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium"
          style="background-color:${aptColor}20;color:${aptColor};box-shadow:inset 0 0 0 1px ${aptColor}40">
          ${escHtml(r.apt_name)}
        </span>
        <span class="text-xs text-slate-400">${r.num_guests} gost${r.num_guests === 1 ? '' : r.num_guests < 5 ? 'a' : 'u'}</span>
        <span class="text-xs text-slate-400">· ${payLabel}</span>
      </div>

      <div class="grid grid-cols-3 gap-2 mb-3">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Check-in</p>
          <p class="text-sm font-semibold text-slate-800">${fmtDate(r.check_in)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Check-out</p>
          <p class="text-sm font-semibold text-slate-800">${fmtDate(r.check_out)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Noćenja</p>
          <p class="text-sm font-semibold text-slate-800">${r.nocenja}</p>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-2 mb-5">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Bruto</p>
          <p class="text-sm font-semibold text-slate-800">${fmtCurr(r.amount_gross)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Provizija</p>
          <p class="text-sm font-semibold text-slate-800">${fmtCurr(r.commission)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Neto</p>
          <p class="text-sm font-bold text-slate-900">${fmtCurr(r.neto > 0 ? r.neto : 0)}</p>
        </div>
      </div>

      <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2">Status provjera</p>
      <div class="space-y-0 mb-1">
        <div class="flex items-center justify-between py-3 border-b border-slate-100">
          <span class="text-sm text-slate-700">Dokumenti primljeni</span>
          ${toggleBtnHtml(r.id, 'documents_received', r.documents_received)}
        </div>
        <div class="flex items-center justify-between py-3 border-b border-slate-100">
          <span class="text-sm text-slate-700">Gosti prijavljeni</span>
          ${toggleBtnHtml(r.id, 'guests_registered', r.guests_registered)}
        </div>
        <div class="flex items-center justify-between py-3 border-b border-slate-100">
          <span class="text-sm text-slate-700">Plaćeno</span>
          ${toggleBtnHtml(r.id, 'is_paid', r.is_paid)}
        </div>
      </div>

      ${cleaningHtml}
      ${actionsHtml}
    `;
  }

  function openRezDrawer(el: HTMLElement) {
    const r = JSON.parse((el as HTMLElement).dataset.rez || '{}');
    _drawerRezId = r.id;
    const body = document.getElementById('rez-drawer-body');
    if (body) body.innerHTML = renderDrawerContent(r);
    document.getElementById('rez-drawer')?.classList.remove('translate-y-full');
    document.getElementById('rez-drawer-overlay')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeRezDrawer() {
    document.getElementById('rez-drawer')?.classList.add('translate-y-full');
    document.getElementById('rez-drawer-overlay')?.classList.add('hidden');
    document.body.style.overflow = '';
    _drawerRezId = null;
  }

  function editFromDrawer(btn: HTMLElement) {
    const data = JSON.parse(btn.dataset.editRez || '{}');
    closeRezDrawer();
    (window as any).openEditModal(data);
  }

  function cancelFromDrawer(btn: HTMLElement) {
    closeRezDrawer();
    (window as any).confirmCancel(btn.dataset.cancelId, btn.dataset.cancelName);
  }

  (window as any).openRezDrawer  = openRezDrawer;
  (window as any).closeRezDrawer = closeRezDrawer;
  (window as any).editFromDrawer = editFromDrawer;
  (window as any).cancelFromDrawer = cancelFromDrawer;
</script>

<script>
  function closeModalOnOverlay(event: MouseEvent, id: string) {
    if (event.target === document.getElementById(id)) {
      document.getElementById(id)?.classList.add('hidden');
    }
  }

  function openAddModal() {
    document.getElementById('modal-add')?.classList.remove('hidden');
    // Resetiraj grešku
    const err = document.getElementById('add-error');
    if (err) err.classList.add('hidden');
  }

  function openEditModal(r: {
    id: string; apartment_id: string; guest_name: string; guest_phone: string;
    check_in: string; check_out: string; num_guests: number; payment_type: string;
    amount_gross: number | string; commission: number | string;
  }) {
    (document.getElementById('edit-id') as HTMLInputElement).value = r.id;
    (document.getElementById('edit-guest_name') as HTMLInputElement).value = r.guest_name;
    (document.getElementById('edit-guest_phone') as HTMLInputElement).value = r.guest_phone;
    (document.getElementById('edit-apartment_id') as HTMLSelectElement).value = r.apartment_id;
    (document.getElementById('edit-check_in') as HTMLInputElement).value = r.check_in;
    (document.getElementById('edit-check_out') as HTMLInputElement).value = r.check_out;
    (document.getElementById('edit-num_guests') as HTMLInputElement).value = String(r.num_guests);
    (document.getElementById('edit-payment_type') as HTMLSelectElement).value = r.payment_type;
    (document.getElementById('edit-amount_gross') as HTMLInputElement).value = String(r.amount_gross);
    (document.getElementById('edit-commission') as HTMLInputElement).value = String(r.commission);
    // Resetiraj grešku
    const err = document.getElementById('edit-error');
    if (err) err.classList.add('hidden');
    document.getElementById('modal-edit')?.classList.remove('hidden');
  }

  function showModalError(errorDivId: string, errorTextId: string, message: string) {
    const div = document.getElementById(errorDivId);
    const txt = document.getElementById(errorTextId);
    if (div && txt) {
      txt.textContent = message;
      div.classList.remove('hidden');
      div.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
    }
  }

  function setSubmitLoading(btnId: string, loading: boolean) {
    const btn = document.getElementById(btnId) as HTMLButtonElement | null;
    if (!btn) return;
    btn.disabled = loading;
    btn.textContent = loading ? 'Spremanje...' : btn.id === 'add-submit' ? 'Spremi' : 'Spremi promjene';
  }

  // AJAX submit — Dodaj
  document.getElementById('form-add')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    setSubmitLoading('add-submit', true);
    const form = e.target as HTMLFormElement;
    const res = await fetch('/api/rezervacije/create', { method: 'POST', body: new FormData(form) });
    const data = await res.json();
    setSubmitLoading('add-submit', false);
    if (!res.ok) {
      showModalError('add-error', 'add-error-text', data.error ?? 'Greška pri kreiranju.');
    } else {
      window.location.href = '/rezervacije?success=created';
    }
  });

  // AJAX submit — Uredi
  document.getElementById('form-edit')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    setSubmitLoading('edit-submit', true);
    const form = e.target as HTMLFormElement;
    const res = await fetch('/api/rezervacije/update', { method: 'POST', body: new FormData(form) });
    const data = await res.json();
    setSubmitLoading('edit-submit', false);
    if (!res.ok) {
      showModalError('edit-error', 'edit-error-text', data.error ?? 'Greška pri ažuriranju.');
    } else {
      window.location.href = '/rezervacije?success=updated';
    }
  });

  function confirmCancel(id: string, name: string) {
    (document.getElementById('cancel-id') as HTMLInputElement).value = id;
    (document.getElementById('cancel-name') as HTMLElement).textContent = name;
    document.getElementById('modal-cancel')?.classList.remove('hidden');
  }

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.className = `fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg ${
      type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'
    }`;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  async function toggleField(id: string, field: string, currentValue: boolean) {
    try {
      const res = await fetch('/api/rezervacije/toggle-field', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, field, value: !currentValue }),
      });
      const data = await res.json();
      if (res.ok && data.success) {
        // Vizualno ažuriraj gumb bez reloada
        const row = document.getElementById(`row-${id}`);
        if (row) {
          const btn = row.querySelector(`[data-field="${field}"]`) as HTMLButtonElement | null;
          if (btn) {
            const newVal = !currentValue;
            btn.setAttribute('onclick', `toggleField('${id}', '${field}', ${newVal})`);
            if (newVal) {
              btn.className = btn.className
                .replace('border-gray-300 text-transparent hover:border-gray-400', '')
                + ' bg-green-500 border-green-500 text-white';
            } else {
              btn.className = btn.className
                .replace('bg-green-500 border-green-500 text-white', '')
                + ' border-gray-300 text-transparent hover:border-gray-400';
            }
          }
        }
        // Ažuriraj drawer toggle button (ako je otvoren za ovu rezervaciju)
        const drawerBtn = document.querySelector<HTMLButtonElement>(`#rez-drawer-body [data-field="${field}"]`);
        if (drawerBtn) {
          drawerBtn.setAttribute('onclick', `toggleField('${id}','${field}',${newVal})`);
          const on  = 'bg-green-500 border-green-500 text-white';
          const off = 'border-slate-200 text-transparent';
          drawerBtn.className = drawerBtn.className.replace(newVal ? off : on, '').trim()
            + ' ' + (newVal ? on : off);
        }
        // Ažuriraj indikator na mobilnoj kartici
        const card = document.getElementById(`mobile-card-${id}`);
        if (card) {
          const dot = card.querySelector<HTMLElement>(`[data-indicator="${field}"]`);
          if (dot) {
            const on  = 'bg-green-500 border-green-500 text-white';
            const off = 'border-slate-200 text-transparent';
            dot.className = dot.className.replace(newVal ? off : on, '').trim() + ' ' + (newVal ? on : off);
          }
          try {
            const rd = JSON.parse(card.dataset.rez || '{}');
            rd[field] = newVal;
            card.dataset.rez = JSON.stringify(rd);
          } catch {}
        }
        showToast('Ažurirano.');
      } else {
        showToast(data.error ?? 'Greška pri ažuriranju.', 'error');
      }
    } catch {
      showToast('Greška pri slanju zahtjeva.', 'error');
    }
  }

  function confirmDeleteRez(id: string, guestName: string) {
    (document.getElementById('delete-rez-id') as HTMLInputElement).value = id;
    (document.getElementById('delete-rez-name') as HTMLElement).textContent = guestName;
    document.getElementById('modal-edit')?.classList.add('hidden');
    document.getElementById('modal-delete-rez')?.classList.remove('hidden');
  }

  async function doDeleteRez() {
    const id = (document.getElementById('delete-rez-id') as HTMLInputElement).value;
    const btn = document.querySelector('#modal-delete-rez .btn-danger') as HTMLButtonElement;
    if (btn) { btn.disabled = true; btn.textContent = 'Brisanje...'; }
    try {
      const res = await fetch('/api/rezervacije/delete', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id }),
      });
      const data = await res.json();
      if (res.ok) {
        window.location.href = '/rezervacije?success=deleted';
      } else {
        document.getElementById('modal-delete-rez')?.classList.add('hidden');
        showToast(data.error ?? 'Greška pri brisanju.', 'error');
      }
    } catch {
      showToast('Greška pri slanju zahtjeva.', 'error');
    } finally {
      if (btn) { btn.disabled = false; btn.textContent = 'Obriši'; }
    }
  }

  function toggleCleaningDropdown(reservationId: string) {
    const dd = document.getElementById(`cleaning-dd-${reservationId}`);
    if (!dd) return;
    const isHidden = dd.classList.contains('hidden');
    // Zatvori sve ostale dropdownove
    document.querySelectorAll('[id^="cleaning-dd-"]').forEach((el) => el.classList.add('hidden'));
    if (isHidden) dd.classList.remove('hidden');
  }

  async function saveCleaningAssignees(reservationId: string, checkOut: string) {
    const userCheckboxes = document.querySelectorAll<HTMLInputElement>(
      `.cleaning-cb[data-res="${reservationId}"][data-type="user"]:checked`
    );
    const extCheckboxes = document.querySelectorAll<HTMLInputElement>(
      `.cleaning-cb[data-res="${reservationId}"][data-type="external"]:checked`
    );
    const userIds = Array.from(userCheckboxes).map((cb) => cb.value);
    const externalIds = Array.from(extCheckboxes).map((cb) => cb.value);
    const totalCount = userIds.length + externalIds.length;

    try {
      const res = await fetch('/api/rezervacije/assign-cleaning', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reservation_id: reservationId, user_ids: userIds, external_ids: externalIds }),
      });
      const data = await res.json();
      if (res.ok) {
        showToast(totalCount > 0 ? `${totalCount} čistač(a) dodijeljen(o), zadatak kreiran.` : 'Dodjela čišćenja uklonjena.');
        // Ažuriraj desktop dropdown labelu
        const btn = document.querySelector<HTMLButtonElement>(`#cleaning-wrap-${reservationId} button`);
        if (btn) {
          const allLabels = Array.from(document.querySelectorAll<HTMLInputElement>(`.cleaning-cb[data-res="${reservationId}"]:checked`))
            .map((cb) => (cb.closest('label')?.querySelector('span')?.textContent?.split(' ')[0] ?? ''));
          const span = btn.querySelector('span');
          if (span) {
            span.className = allLabels.length > 0 ? 'truncate' : 'text-slate-400';
            span.textContent = allLabels.length > 0 ? allLabels.join(', ') : '— Odaberi —';
          }
        }
        document.getElementById(`cleaning-dd-${reservationId}`)?.classList.add('hidden');

        // Ažuriraj globalni _cleaningData i mobilnu karticu
        const updatedCleaners = Array.from(document.querySelectorAll<HTMLInputElement>(
          `.cleaning-cb[data-res="${reservationId}"]:checked`
        )).map((cb) => ({
          id: cb.value,
          type: cb.dataset.type as 'user' | 'external',
          full_name: cb.closest('label')?.querySelector('span')?.textContent?.replace(/\s*\(Pomoćno\)\s*/, '').trim() ?? '',
        }));
        (window as any)._cleaningData[reservationId] = updatedCleaners;
        // Ažuriraj prikaz čistača na mobilnoj kartici
        const cleanerSpan = document.getElementById(`card-cleaners-${reservationId}`);
        if (cleanerSpan) {
          const names = updatedCleaners.map((c: any) => c.full_name.split(' ')[0]).join(', ');
          cleanerSpan.textContent = names;
          cleanerSpan.classList.toggle('hidden', names.length === 0);
        }
      } else {
        showToast(data.error ?? 'Greška pri dodjeli čišćenja.', 'error');
      }
    } catch {
      showToast('Greška pri slanju zahtjeva.', 'error');
    }
  }

  // Zatvori dropdown klikom izvan
  document.addEventListener('click', (e) => {
    if (!(e.target as Element).closest('[id^="cleaning-wrap-"]')) {
      document.querySelectorAll('[id^="cleaning-dd-"]').forEach((el) => el.classList.add('hidden'));
    }
  });

  window.closeModalOnOverlay = closeModalOnOverlay;
  window.openAddModal = openAddModal;
  window.openEditModal = openEditModal;
  window.confirmCancel = confirmCancel;
  window.toggleField = toggleField;
  window.toggleCleaningDropdown = toggleCleaningDropdown;
  window.saveCleaningAssignees = saveCleaningAssignees;
  window.confirmDeleteRez = confirmDeleteRez;
  window.doDeleteRez = doDeleteRez;

  // Prikaži success/error iz URL-a kao toast i očisti URL
  const _params = new URLSearchParams(window.location.search);
  const _success = _params.get('success');
  const _error = _params.get('error');
  const _successMessages: Record<string, string> = {
    created: 'Rezervacija je uspješno kreirana.',
    updated: 'Rezervacija je uspješno ažurirana.',
    deleted: 'Rezervacija je obrisana.',
    cancelled: 'Rezervacija je otkazana.',
  };
  if (_success && _successMessages[_success]) showToast(_successMessages[_success], 'success');
  if (_error) showToast(decodeURIComponent(_error), 'error');
  if (_success || _error) {
    const _url = new URL(window.location.href);
    _url.searchParams.delete('success');
    _url.searchParams.delete('error');
    history.replaceState({}, '', _url.toString());
  }
</script>
