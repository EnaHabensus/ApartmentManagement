---
// Scenarij B: postojeći korisnik prihvaća pozivnicu
import '../../styles/global.css';
import { createSupabaseAdminClient, createSupabaseServerClient } from '../../lib/supabase';

const token = Astro.url.searchParams.get('token');
if (!token) return Astro.redirect('/login');

const supabase = createSupabaseAdminClient();
const { data: invite } = await supabase
  .from('invite_tokens')
  .select('*')
  .eq('id', token)
  .single();

if (!invite || invite.accepted_at || new Date(invite.expires_at) < new Date()) {
  return Astro.redirect('/login?error=Pozivnica+nije+valjana+ili+je+istekla.');
}

// Provjeri je li korisnik prijavljen
const serverSupabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await serverSupabase.auth.getUser();

if (!user) {
  // Nije prijavljen — preusmjeri na login s token parametrom
  return Astro.redirect(`/login?invite_token=${token}`);
}

// Korisnik je prijavljen — odmah prihvati pozivnicu
for (const apartmentId of invite.apartment_ids) {
  await supabase
    .from('apartment_users')
    .upsert({
      apartment_id: apartmentId,
      user_id: user.id,
      role: invite.role,
      added_by: invite.invited_by,
    }, { onConflict: 'apartment_id,user_id' });
}

await supabase
  .from('invite_tokens')
  .update({ accepted_at: new Date().toISOString() })
  .eq('id', token);

return Astro.redirect('/?invited=1');
---
