---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';
import type { ApartmentUserWithProfile } from '../lib/types';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;

// Koristimo admin klijent za sve upite — izbjegavamo RLS probleme
const adminSupabase = createSupabaseAdminClient();

// Dohvati apartment_ids gdje je korisnik admin (bez joins — jednostavno i pouzdano)
const { data: myAdminRows } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id, role')
  .eq('user_id', user.id);

const adminApartmentIds = (myAdminRows ?? []).filter((r) => r.role === 'admin').map((r) => r.apartment_id);
const hasAnyEntries = (myAdminRows ?? []).length > 0;

if (hasAnyEntries && adminApartmentIds.length === 0) {
  return Astro.redirect('/zadatci');
}

// Dohvati nazive apartmana zasebno
const { data: adminApartmentData } = await adminSupabase
  .from('apartments')
  .select('id, name, color')
  .in('id', adminApartmentIds)
  .eq('is_deleted', false);

const adminApartments = adminApartmentData ?? [];

// Filter po apartmanu
const filterApartmentId = Astro.url.searchParams.get('apartment_id') ?? '';

// Dohvati apartment_users zapise (bez joins)
const auQuery = adminSupabase
  .from('apartment_users')
  .select('id, apartment_id, user_id, role, added_at')
  .in('apartment_id', adminApartmentIds);

const { data: apartmentUsers } = filterApartmentId
  ? await auQuery.eq('apartment_id', filterApartmentId)
  : await auQuery;

// Dohvati profile zasebno za sve user_ids
const userIds = [...new Set((apartmentUsers ?? []).map((au) => au.user_id))];

const { data: profilesData } = userIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name, email, has_logged_in').in('id', userIds)
  : { data: [], error: null };

const profilesMap = new Map((profilesData ?? []).map((p) => [p.id, p]));

// Grupiraj po korisnicima (uniqui korisnici s listom apartmana)
const usersMap = new Map<string, {
  user_id: string;
  full_name: string;
  email: string;
  has_logged_in: boolean;
  apartments: Array<{ apartment_id: string; apartment_name: string; role: string; color: string }>;
}>();

const apartmentsNameMap = new Map((adminApartments ?? []).map((a) => [a.id, a.name]));
const apartmentsColorMap = new Map((adminApartments ?? []).map((a) => [a.id, (a as any).color as string ?? '#3B82F6']));

for (const au of (apartmentUsers ?? [])) {
  const p = profilesMap.get(au.user_id);
  const full_name = p?.full_name ?? 'Nepoznat korisnik';
  const email = p?.email ?? '';
  const has_logged_in = p?.has_logged_in ?? false;

  const existing = usersMap.get(au.user_id);
  const aptEntry = {
    apartment_id: au.apartment_id,
    apartment_name: apartmentsNameMap.get(au.apartment_id) ?? '',
    role: au.role,
    color: apartmentsColorMap.get(au.apartment_id) ?? '#3B82F6',
  };
  if (existing) {
    existing.apartments.push(aptEntry);
  } else {
    usersMap.set(au.user_id, {
      user_id: au.user_id,
      full_name,
      email,
      has_logged_in,
      apartments: [aptEntry],
    });
  }
}

const users = Array.from(usersMap.values());

// Dohvati pending invite tokene (neprihvaćeni, neistekli)
const { data: pendingInviteRows } = await adminSupabase
  .from('invite_tokens')
  .select('id, email, full_name, apartment_ids, role, created_at')
  .is('accepted_at', null)
  .gt('expires_at', new Date().toISOString());

// Filtriraj samo invite-ove za admin-ove apartmane
const existingEmails = new Set(users.map((u) => u.email));
const pendingInvites = (pendingInviteRows ?? [])
  .filter((inv) => inv.apartment_ids.some((aptId: string) => adminApartmentIds.includes(aptId)))
  .filter((inv) => !existingEmails.has(inv.email))
  .filter((inv) => !filterApartmentId || inv.apartment_ids.includes(filterApartmentId))
  .map((inv) => ({
    invite_id: inv.id as string,
    full_name: (inv.full_name as string) || inv.email.split('@')[0],
    email: inv.email as string,
    role: inv.role as string,
    apartments: (inv.apartment_ids as string[])
      .filter((aptId) => adminApartmentIds.includes(aptId))
      .map((aptId) => ({
        apartment_id: aptId,
        apartment_name: apartmentsNameMap.get(aptId) ?? '',
        role: inv.role as string,
        color: apartmentsColorMap.get(aptId) ?? '#3B82F6',
      })),
  }));

const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<AppLayout title="Korisnici" user={profile} isAdmin={true} activeRoute="/korisnici">
  <div class="p-6 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Korisnici</h1>
        <p class="text-gray-500 text-sm mt-1">{users.length} korisnik{users.length === 1 ? '' : users.length < 5 ? 'a' : 'a'}</p>
      </div>
      <button
        onclick="document.getElementById('modal-add').classList.remove('hidden')"
        class="btn-primary"
      >
        + Dodaj korisnika
      </button>
    </div>


    <!-- Filter apartmana -->
    <div class="mb-4 flex items-center gap-3">
      <label class="label mb-0 text-sm font-medium text-gray-700 whitespace-nowrap">Filter apartmana:</label>
      <form method="GET" action="/korisnici">
        <select
          name="apartment_id"
          onchange="this.form.submit()"
          class="input py-1.5 text-sm"
        >
          <option value="">Svi apartmani</option>
          {adminApartments.map((apt) => (
            <option value={apt.id} selected={filterApartmentId === apt.id}>
              {apt.name}
            </option>
          ))}
        </select>
      </form>
    </div>

    <!-- Tablica korisnika -->
    {users.length === 0 && pendingInvites.length === 0 ? (
      <div class="card p-12 text-center">
        <div class="text-gray-400 mb-4">
          <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Nema korisnika</h3>
        <p class="text-gray-500 mb-6">Pozovite prvog korisnika da biste počeli upravljati apartmanom.</p>
        <button
          onclick="document.getElementById('modal-add').classList.remove('hidden')"
          class="btn-primary"
        >
          + Dodaj korisnika
        </button>
      </div>
    ) : (
      <div class="overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
        <table class="text-sm" style="min-width: 700px; width: 100%;">
          <thead>
            <tr>
              <th class="table-head px-4 py-3 text-left whitespace-nowrap">Ime i prezime</th>
              <th class="table-head px-4 py-3 text-left">Email</th>
              <th class="table-head px-4 py-3 text-left">Uloga</th>
              <th class="table-head px-4 py-3 text-left">Status</th>
              <th class="table-head px-4 py-3 text-left">Apartmani</th>
              <th class="table-head px-4 py-3 text-left">Akcije</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-gray-100">
            {users.map((u) => (
              <tr class="table-row">
                <td class="table-cell px-4 py-3 font-medium text-gray-900 whitespace-nowrap">{u.full_name}</td>
                <td class="table-cell px-4 py-3 text-gray-500">{u.email}</td>
                <td class="table-cell px-4 py-3">
                  <div class="flex flex-wrap gap-1">
                    {u.apartments.map((apt) => (
                      <span class={`badge ${apt.role === 'admin' ? 'badge-blue' : 'badge-gray'}`}>
                        {apt.role === 'admin' ? 'Admin' : 'Staff'}
                      </span>
                    ))}
                  </div>
                </td>
                <td class="table-cell px-4 py-3">
                  {u.has_logged_in ? (
                    <span class="badge badge-green">Aktivan</span>
                  ) : (
                    <span class="badge bg-yellow-100 text-yellow-700">Pozvan</span>
                  )}
                </td>
                <td class="table-cell px-4 py-3">
                  <div class="flex flex-wrap gap-1">
                    {u.apartments.map((apt) => (
                      <span
                        class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium whitespace-nowrap"
                        style={`background-color: ${apt.color}20; color: ${apt.color}; box-shadow: inset 0 0 0 1px ${apt.color}40`}
                      >{apt.apartment_name}</span>
                    ))}
                  </div>
                </td>
                <td class="table-cell px-4 py-3">
                  <div class="flex items-center gap-1">
                    <button
                      onclick={`openEditModal(${JSON.stringify(u)})`}
                      class="btn-ghost text-xs px-2 py-1"
                    >
                      Uredi
                    </button>
                    <button
                      onclick={`confirmDelete('${u.user_id}', '${u.full_name}', ${JSON.stringify(u.apartments.map((a) => a.apartment_id))})`}
                      class="btn-ghost text-xs px-2 py-1 text-red-500 hover:bg-red-50 hover:text-red-700"
                    >
                      Obriši
                    </button>
                  </div>
                </td>
              </tr>
            ))}
            {pendingInvites.map((inv) => (
              <tr class="table-row bg-orange-50/30">
                <td class="table-cell px-4 py-3 font-medium text-gray-900 whitespace-nowrap">{inv.full_name}</td>
                <td class="table-cell px-4 py-3 text-gray-500">{inv.email}</td>
                <td class="table-cell px-4 py-3">
                  <span class={`badge ${inv.role === 'admin' ? 'badge-blue' : 'badge-gray'}`}>
                    {inv.role === 'admin' ? 'Admin' : 'Staff'}
                  </span>
                </td>
                <td class="table-cell px-4 py-3">
                  <span class="badge bg-orange-100 text-orange-700">Pozivnica poslana</span>
                </td>
                <td class="table-cell px-4 py-3">
                  <div class="flex flex-wrap gap-1">
                    {inv.apartments.map((apt) => (
                      <span
                        class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium whitespace-nowrap"
                        style={`background-color: ${apt.color}20; color: ${apt.color}; box-shadow: inset 0 0 0 1px ${apt.color}40`}
                      >{apt.apartment_name}</span>
                    ))}
                  </div>
                </td>
                <td class="table-cell px-4 py-3">
                  <form action="/api/invite/cancel" method="POST">
                    <input type="hidden" name="token_id" value={inv.invite_id} />
                    <button
                      type="submit"
                      class="btn-ghost text-xs px-2 py-1 text-orange-600 hover:bg-orange-50 hover:text-orange-700"
                    >
                      Poništi pozivnicu
                    </button>
                  </form>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}
  </div>

  <!-- Modal: Dodaj korisnika -->
  <div id="modal-add" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-add')">
    <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Dodaj korisnika</h2>
        <p class="text-sm text-gray-500 mt-1">Korisnik će primiti email s pozivnicom.</p>
      </div>
      <div class="p-6 space-y-5" id="form-add-wrapper">
        <div>
          <label class="label">Email *</label>
          <input id="add-email" type="email" required class="input" placeholder="korisnik@email.com" />
        </div>
        <div>
          <label class="label">Ime i prezime *</label>
          <input id="add-full_name" type="text" required class="input" placeholder="Ime Prezime" />
        </div>
        <div>
          <label class="label">Uloga</label>
          <select id="add-role" class="input">
            <option value="staff">Staff</option>
            <option value="admin">Admin</option>
          </select>
        </div>
        <div>
          <label class="label">Apartmani *</label>
          <div class="space-y-2 mt-1">
            {adminApartments.map((apt) => (
              <label class="flex items-center gap-2 cursor-pointer">
                <input
                  type="checkbox"
                  name="apartment_ids"
                  value={apt.id}
                  class="add-apt-checkbox h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                />
                <span class="text-sm text-gray-700">{apt.name}</span>
              </label>
            ))}
          </div>
        </div>

        <div id="add-error" class="hidden rounded-lg bg-red-50 border border-red-200 p-3">
          <p class="text-sm text-red-600" id="add-error-msg"></p>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button
            type="button"
            onclick="document.getElementById('modal-add').classList.add('hidden')"
            class="btn-secondary"
          >
            Odustani
          </button>
          <button
            type="button"
            id="btn-send-invite"
            onclick="sendInvite()"
            class="btn-primary"
          >
            Pošalji pozivnicu
          </button>
        </div>
      </div>
    </div>
  </div>

  <!-- Modal: Uredi korisnika -->
  <div id="modal-edit" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-edit')">
    <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Uredi korisnika</h2>
      </div>
      <form action="/api/korisnici/update" method="POST" class="p-6 space-y-5" id="form-edit">
        <input type="hidden" name="user_id" id="edit-user_id" />
        <input type="hidden" name="apartment_roles" id="edit-apartment_roles" />

        <div>
          <label class="label">Ime i prezime</label>
          <input id="edit-full_name" name="full_name" type="text" required class="input" />
        </div>
        <div>
          <label class="label">Email</label>
          <input id="edit-email-display" type="email" disabled class="input bg-gray-50 text-gray-500 cursor-not-allowed" />
        </div>

        <div>
          <label class="label">Apartmani i uloge</label>
          <div id="edit-apartments-list" class="space-y-3 mt-1">
            <!-- Dynamically filled via JS -->
          </div>
        </div>

        <div>
          <label class="label">Dodaj na apartman</label>
          <div class="space-y-2 mt-1" id="edit-add-apartments">
            {adminApartments.map((apt) => (
              <label class="flex items-center gap-2 cursor-pointer edit-apt-add-row" data-apt-id={apt.id} data-apt-name={apt.name}>
                <input
                  type="checkbox"
                  class="edit-apt-checkbox h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                  data-apt-id={apt.id}
                />
                <span class="text-sm text-gray-700">{apt.name}</span>
              </label>
            ))}
          </div>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button
            type="button"
            onclick="document.getElementById('modal-edit').classList.add('hidden')"
            class="btn-secondary"
          >
            Odustani
          </button>
          <button type="submit" onclick="prepareEditSubmit()" class="btn-primary">
            Spremi
          </button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Potvrda brisanja -->
  <div id="modal-delete" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-delete')">
    <div class="modal-content p-6" onclick="event.stopPropagation()">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Ukloni korisnika</h2>
      <p class="text-gray-600 mb-2">
        Jeste li sigurni da želite ukloniti <strong id="delete-name"></strong> s apartmana?
      </p>
      <p class="text-sm text-gray-500 mb-2">Odaberite s kojeg apartmana želite ukloniti korisnika:</p>
      <form action="/api/korisnici/delete" method="POST">
        <input type="hidden" name="user_id" id="delete-user_id" />
        <div id="delete-apartments-list" class="space-y-2 mb-6">
          <!-- Filled via JS -->
        </div>
        <div class="flex justify-end gap-3">
          <button
            type="button"
            onclick="document.getElementById('modal-delete').classList.add('hidden')"
            class="btn-secondary"
          >
            Odustani
          </button>
          <button type="submit" class="btn-danger">Ukloni</button>
        </div>
      </form>
    </div>
  </div>
</AppLayout>

<script>
  // ─── Helpers ─────────────────────────────────────────────────────────────────

  function closeModalOnOverlay(event: MouseEvent, id: string) {
    if (event.target === document.getElementById(id)) {
      document.getElementById(id)?.classList.add('hidden');
    }
  }

  function toggleDropdown(id: string) {
    // Zatvori sve ostale dropdowne
    document.querySelectorAll('[id^="dropdown-"]').forEach((el) => {
      if (el.id !== id) el.classList.add('hidden');
    });
    document.getElementById(id)?.classList.toggle('hidden');
  }

  // Zatvori dropdown klikom izvan
  document.addEventListener('click', (e: MouseEvent) => {
    const target = e.target as HTMLElement;
    if (!target.closest('[id^="dropdown-"]') && !target.closest('button[onclick*="toggleDropdown"]')) {
      document.querySelectorAll('[id^="dropdown-"]').forEach((el) => el.classList.add('hidden'));
    }
  });

  // ─── Modal Dodaj ─────────────────────────────────────────────────────────────

  async function sendInvite() {
    const email = (document.getElementById('add-email') as HTMLInputElement).value.trim();
    const fullName = (document.getElementById('add-full_name') as HTMLInputElement).value.trim();
    const role = (document.getElementById('add-role') as HTMLSelectElement).value;
    const checkboxes = document.querySelectorAll<HTMLInputElement>('.add-apt-checkbox:checked');
    const apartment_ids = Array.from(checkboxes).map((cb) => cb.value);

    const errorEl = document.getElementById('add-error')!;
    const errorMsg = document.getElementById('add-error-msg')!;
    errorEl.classList.add('hidden');

    if (!email || !fullName) {
      errorMsg.textContent = 'Email i ime i prezime su obavezni.';
      errorEl.classList.remove('hidden');
      return;
    }
    if (apartment_ids.length === 0) {
      errorMsg.textContent = 'Odaberite barem jedan apartman.';
      errorEl.classList.remove('hidden');
      return;
    }

    const btn = document.getElementById('btn-send-invite') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Slanje...';

    try {
      const res = await fetch('/api/invite/create', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, full_name: fullName, apartment_ids, role }),
      });
      const data = await res.json();
      if (!res.ok) {
        errorMsg.textContent = data.error ?? 'Greška pri slanju pozivnice.';
        errorEl.classList.remove('hidden');
      } else {
        document.getElementById('modal-add')?.classList.add('hidden');
        window.location.href = '/korisnici?success=invited';
      }
    } catch {
      errorMsg.textContent = 'Greška pri slanju pozivnice.';
      errorEl.classList.remove('hidden');
    } finally {
      btn.disabled = false;
      btn.textContent = 'Pošalji pozivnicu';
    }
  }

  // ─── Modal Uredi ─────────────────────────────────────────────────────────────

  type ApartmentEntry = { apartment_id: string; apartment_name: string; role: string };

  function openEditModal(u: { user_id: string; full_name: string; email: string; apartments: ApartmentEntry[] }) {
    (document.getElementById('edit-user_id') as HTMLInputElement).value = u.user_id;
    (document.getElementById('edit-full_name') as HTMLInputElement).value = u.full_name;
    (document.getElementById('edit-email-display') as HTMLInputElement).value = u.email;

    // Popuni listu apartmana s ulogama
    const list = document.getElementById('edit-apartments-list')!;
    list.innerHTML = '';
    const existingAptIds = new Set(u.apartments.map((a) => a.apartment_id));

    u.apartments.forEach((apt) => {
      const row = document.createElement('div');
      row.className = 'flex items-center gap-3 p-3 bg-gray-50 rounded-lg';
      row.dataset.aptId = apt.apartment_id;
      row.innerHTML = `
        <span class="flex-1 text-sm font-medium text-gray-700">${apt.apartment_name}</span>
        <select class="edit-role-select input py-1 text-sm w-28" data-apt-id="${apt.apartment_id}">
          <option value="staff" ${apt.role === 'staff' ? 'selected' : ''}>Staff</option>
          <option value="admin" ${apt.role === 'admin' ? 'selected' : ''}>Admin</option>
        </select>
      `;
      list.appendChild(row);
    });

    // Prikaži checkboxove samo za apartmane na kojima korisnik NIJE
    const addRows = document.querySelectorAll<HTMLElement>('.edit-apt-add-row');
    addRows.forEach((row) => {
      const aptId = row.dataset.aptId ?? '';
      const cb = row.querySelector<HTMLInputElement>('.edit-apt-checkbox')!;
      cb.checked = false;
      row.style.display = existingAptIds.has(aptId) ? 'none' : 'flex';
    });

    document.getElementById('modal-edit')?.classList.remove('hidden');
  }

  function prepareEditSubmit() {
    const roleSelects = document.querySelectorAll<HTMLSelectElement>('.edit-role-select');
    const aptRoles: Array<{ apartment_id: string; role: string }> = [];

    roleSelects.forEach((sel) => {
      aptRoles.push({ apartment_id: sel.dataset.aptId!, role: sel.value });
    });

    // Dodaj nove apartmane iz checkboxova
    const newCbs = document.querySelectorAll<HTMLInputElement>('.edit-apt-checkbox:checked');
    newCbs.forEach((cb) => {
      aptRoles.push({ apartment_id: cb.dataset.aptId!, role: 'staff' });
    });

    (document.getElementById('edit-apartment_roles') as HTMLInputElement).value = JSON.stringify(aptRoles);
  }

  // ─── Modal Obriši ─────────────────────────────────────────────────────────────

  function confirmDelete(userId: string, fullName: string, apartmentIds: string[]) {
    (document.getElementById('delete-user_id') as HTMLInputElement).value = userId;
    document.getElementById('delete-name')!.textContent = fullName;

    // Popuni listu apartmana za odabir brisanja
    const list = document.getElementById('delete-apartments-list')!;
    list.innerHTML = '';

    // Dohvati nazive apartmana iz DOM-a (badge elementi u retku)
    // Koristimo apartmentIds da kreiramo radio opcije
    apartmentIds.forEach((aptId, idx) => {
      // Pokušaj naći naziv iz tablice
      const aptBadges = document.querySelectorAll(`[data-apt-id="${aptId}"]`);
      let aptName = aptId;
      if (aptBadges.length > 0) {
        aptName = (aptBadges[0] as HTMLElement).dataset.aptName ?? aptId;
      }

      const label = document.createElement('label');
      label.className = 'flex items-center gap-2 cursor-pointer';
      label.innerHTML = `
        <input type="radio" name="apartment_id" value="${aptId}" class="h-4 w-4" ${idx === 0 ? 'required checked' : ''} />
        <span class="text-sm text-gray-700">${aptName}</span>
      `;
      list.appendChild(label);
    });

    document.getElementById('modal-delete')?.classList.remove('hidden');
  }

  // Expose to global scope
  (window as any).closeModalOnOverlay = closeModalOnOverlay;
  (window as any).toggleDropdown = toggleDropdown;
  (window as any).sendInvite = sendInvite;
  (window as any).openEditModal = openEditModal;
  (window as any).prepareEditSubmit = prepareEditSubmit;
  (window as any).confirmDelete = confirmDelete;

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    let toast = document.getElementById('_toast');
    if (!toast) { toast = document.createElement('div'); toast.id = '_toast'; document.body.appendChild(toast); }
    toast.textContent = message;
    toast.className = `fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg ${type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'}`;
    setTimeout(() => toast!.remove(), 3500);
  }
  const _p = new URLSearchParams(window.location.search);
  const _s = _p.get('success'), _e = _p.get('error');
  const _m: Record<string, string> = { updated: 'Korisnik je uspješno ažuriran.', deleted: 'Korisnik je uspješno uklonjen.', invited: 'Pozivnica je uspješno poslana.', invite_cancelled: 'Pozivnica je poništena.' };
  if (_s && _m[_s]) showToast(_m[_s], 'success');
  if (_e) showToast(decodeURIComponent(_e), 'error');
  if (_s || _e) { const _url = new URL(window.location.href); _url.searchParams.delete('success'); _url.searchParams.delete('error'); history.replaceState({}, '', _url.toString()); }
</script>
