---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;
const isAdmin = Astro.locals.isAdmin ?? false;
const adminSupabase = createSupabaseAdminClient();

// Dohvati apartmane ovog korisnika (za multi-select u formi)
const { data: myAptUsers } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id')
  .eq('user_id', user.id);
const myAptIds = (myAptUsers ?? []).map((au) => au.apartment_id);

const { data: myApartments } = myAptIds.length > 0
  ? await adminSupabase.from('apartments').select('id, name, color').in('id', myAptIds).eq('is_deleted', false).order('name')
  : { data: [] };

// Dohvati predloške
const { data: rawTemplates } = await adminSupabase
  .from('templates')
  .select('*')
  .order('created_at', { ascending: false });

// Dohvati nazive apartmana za prikaz na karticama
const allAptIds = [...new Set((rawTemplates ?? []).flatMap((t) => (t.apartment_ids as string[]) ?? []))];
const { data: aptData } = allAptIds.length > 0
  ? await adminSupabase.from('apartments').select('id, name, color').in('id', allAptIds).eq('is_deleted', false)
  : { data: [] };
const aptMap = new Map((aptData ?? []).map((a) => [a.id, a]));

// Dohvati kreatore
const creatorIds = [...new Set((rawTemplates ?? []).filter((t) => t.created_by).map((t) => t.created_by as string))];
const { data: creatorProfiles } = creatorIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name').in('id', creatorIds)
  : { data: [] };
const creatorMap = new Map((creatorProfiles ?? []).map((p) => [p.id, p.full_name]));

const templates = (rawTemplates ?? []).map((t) => ({
  ...t,
  creator_name: t.created_by ? (creatorMap.get(t.created_by) ?? 'Nepoznat') : null,
  is_mine: t.created_by === user.id,
  apt_ids: (t.apartment_ids as string[]) ?? [],
}));
---

<AppLayout title="Predlošci" user={profile} isAdmin={isAdmin} activeRoute="/predlosci">
  <div class="p-4 md:p-6 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Predlošci</h1>
        <p class="text-gray-500 text-sm mt-1">
          <span id="template-count">{templates.length} predložak{templates.length === 1 ? '' : templates.length < 5 ? 'a' : 'a'}</span>
        </p>
      </div>
      <button onclick="openAddModal()" class="btn-primary">+ Dodaj predložak</button>
    </div>

    <!-- Search + Filter -->
    {templates.length > 0 && (
      <div class="mb-4 flex flex-col md:flex-row gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-2.5 top-1/2 -translate-y-1/2 h-4 w-4 text-gray-400 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
          <input
            type="text"
            id="search-input"
            placeholder="Pretraži predloške..."
            oninput="applyFilters()"
            class="input w-full pl-9"
          />
        </div>
        {aptData && aptData.length > 0 && (
          <select id="apt-filter" onchange="applyFilters()" class="input w-full md:w-56">
            <option value="">Svi apartmani</option>
            {aptData.map((apt) => (
              <option value={apt.id}>{apt.name}</option>
            ))}
          </select>
        )}
      </div>
    )}

    <!-- Lista predložaka -->
    {templates.length === 0 ? (
      <div class="card p-12 text-center">
        <div class="text-gray-400 mb-4">
          <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <rect x="3" y="3" width="18" height="18" rx="2" stroke-width="1.5"/>
            <line x1="9" y1="8" x2="15" y2="8" stroke-width="1.5"/>
            <line x1="7" y1="12" x2="17" y2="12" stroke-width="1.5"/>
            <line x1="7" y1="16" x2="13" y2="16" stroke-width="1.5"/>
          </svg>
        </div>
        <h3 class="text-lg font-medium text-gray-900 mb-2">Nema predložaka</h3>
        <p class="text-gray-500 mb-4">Dodajte prvi predložak poruke za goste.</p>
        <button onclick="openAddModal()" class="btn-primary">+ Dodaj predložak</button>
      </div>
    ) : (
      <>
        <div id="template-grid" class="grid grid-cols-1 md:grid-cols-2 xl:grid-cols-3 gap-4">
          {templates.map((t) => (
            <div
              class="card p-5 flex flex-col gap-3 template-card"
              data-name={t.name.toLowerCase()}
              data-content={t.content.toLowerCase()}
              data-apt-ids={JSON.stringify(t.apt_ids)}
            >
            <!-- Naziv -->
            <h3 class="font-semibold text-gray-900 text-base">{t.name}</h3>

            <!-- Kreator -->
            {t.creator_name && (
              <p class="text-xs text-gray-400 -mt-2">Kreirao: {t.creator_name}</p>
            )}

            <!-- Apartmani -->
            {t.apt_ids.length > 0 && (
              <div class="flex flex-wrap gap-1">
                {t.apt_ids.map((aptId) => {
                  const apt = aptMap.get(aptId);
                  if (!apt) return null;
                  const color = (apt as any).color ?? '#3B82F6';
                  return (
                    <span
                      class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium"
                      style={`background-color: ${color}20; color: ${color}; box-shadow: inset 0 0 0 1px ${color}40`}
                    >
                      {apt.name}
                    </span>
                  );
                })}
              </div>
            )}

            <!-- Sadržaj (preview) -->
            <p class="text-sm text-gray-600 leading-relaxed line-clamp-4 flex-1 whitespace-pre-wrap">{t.content}</p>

            <!-- Akcije -->
            <div class="flex items-center justify-between pt-2 border-t border-gray-100">
              <div class="flex items-center gap-1">
                {(t.is_mine || isAdmin) && (
                  <>
                    <button
                      onclick={`openEditModal(${JSON.stringify({ id: t.id, name: t.name, content: t.content, apartment_ids: t.apt_ids })})`}
                      class="btn-ghost text-xs px-2 py-1"
                    >
                      Uredi
                    </button>
                    <button
                      onclick={`confirmDelete('${t.id}', '${t.name.replace(/'/g, "\\'")}')`}
                      class="btn-ghost text-xs px-2 py-1 text-red-500 hover:bg-red-50 hover:text-red-700"
                    >
                      Obriši
                    </button>
                  </>
                )}
              </div>
              <button
                data-content={t.content}
                onclick="copyTemplate(this)"
                class="inline-flex items-center gap-1.5 rounded-md px-3 py-1.5 text-sm font-medium text-white bg-blue-600 hover:bg-blue-700 transition-colors"
              >
                <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="9" y="9" width="13" height="13" rx="2"/>
                  <path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/>
                </svg>
                Kopiraj
              </button>
            </div>
            </div>
          ))}
        </div>

        <!-- Nema rezultata pretrage -->
        <div id="no-results" class="hidden card p-10 text-center">
          <p class="text-gray-500">Nema predložaka koji odgovaraju pretrazi.</p>
          <button onclick="clearFilters()" class="mt-3 text-sm text-blue-600 hover:underline">Poništi filtere</button>
        </div>
      </>
    )}
  </div>

  <!-- Modal: Dodaj predložak -->
  <div id="modal-add" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-add')">
    <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Dodaj predložak</h2>
      </div>
      <form action="/api/predlosci/create" method="POST" class="p-6 space-y-5" id="form-add">
        <div>
          <label class="label">Naziv predloška *</label>
          <input name="name" type="text" required class="input" placeholder="npr. Check-in poruka" />
        </div>
        <div>
          <label class="label">Sadržaj *</label>
          <textarea name="content" required rows="8" class="input resize-none" placeholder="Unesite tekst predloška..."></textarea>
        </div>
        {(myApartments ?? []).length > 0 && (
          <div>
            <label class="label">Apartmani</label>
            <div class="space-y-2 mt-1">
              {(myApartments ?? []).map((apt) => (
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    class="add-apt-cb h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    value={apt.id}
                  />
                  <span class="text-sm text-gray-700">{apt.name}</span>
                </label>
              ))}
            </div>
            <input type="hidden" name="apartment_ids" id="add-apartment_ids" value="[]" />
          </div>
        )}
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" onclick="document.getElementById('modal-add').classList.add('hidden')" class="btn-secondary">Odustani</button>
          <button type="submit" class="btn-primary">Spremi</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Uredi predložak -->
  <div id="modal-edit" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-edit')">
    <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Uredi predložak</h2>
      </div>
      <form action="/api/predlosci/update" method="POST" class="p-6 space-y-5" id="form-edit">
        <input type="hidden" name="id" id="edit-id" />
        <div>
          <label class="label">Naziv predloška *</label>
          <input id="edit-name" name="name" type="text" required class="input" />
        </div>
        <div>
          <label class="label">Sadržaj *</label>
          <textarea id="edit-content" name="content" required rows="8" class="input resize-none"></textarea>
        </div>
        {(myApartments ?? []).length > 0 && (
          <div>
            <label class="label">Apartmani</label>
            <div class="space-y-2 mt-1">
              {(myApartments ?? []).map((apt) => (
                <label class="flex items-center gap-2 cursor-pointer">
                  <input
                    type="checkbox"
                    class="edit-apt-cb h-4 w-4 rounded border-gray-300 text-blue-600 focus:ring-blue-500"
                    value={apt.id}
                  />
                  <span class="text-sm text-gray-700">{apt.name}</span>
                </label>
              ))}
            </div>
            <input type="hidden" name="apartment_ids" id="edit-apartment_ids" value="[]" />
          </div>
        )}
        <div class="flex justify-end gap-3 pt-2">
          <button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="btn-secondary">Odustani</button>
          <button type="submit" class="btn-primary">Spremi promjene</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Potvrda brisanja -->
  <div id="modal-delete" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-delete')">
    <div class="modal-content p-6" onclick="event.stopPropagation()">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Obriši predložak</h2>
      <p class="text-gray-600 mb-6">
        Jeste li sigurni da želite obrisati predložak <strong id="delete-name"></strong>?
        <br /><span class="text-sm text-red-600">Ova akcija se ne može poništiti.</span>
      </p>
      <form action="/api/predlosci/delete" method="POST">
        <input type="hidden" name="id" id="delete-id" />
        <div class="flex justify-end gap-3">
          <button type="button" onclick="document.getElementById('modal-delete').classList.add('hidden')" class="btn-secondary">Odustani</button>
          <button type="submit" class="btn-danger">Obriši</button>
        </div>
      </form>
    </div>
  </div>

  <div id="toast" class="hidden fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg"></div>
</AppLayout>

<script>
  function closeModalOnOverlay(event, id) {
    if (event.target === document.getElementById(id)) {
      document.getElementById(id)?.classList.add('hidden');
    }
  }

  function showToast(message, type = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.className = `fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg ${
      type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'
    }`;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  function openAddModal() {
    document.getElementById('modal-add')?.querySelector('form')?.reset();
    document.querySelectorAll('.add-apt-cb').forEach((cb) => (cb as HTMLInputElement).checked = false);
    document.getElementById('modal-add')?.classList.remove('hidden');
  }

  function openEditModal(t) {
    document.getElementById('edit-id').value = t.id;
    document.getElementById('edit-name').value = t.name;
    document.getElementById('edit-content').value = t.content;
    document.querySelectorAll('.edit-apt-cb').forEach((cb) => {
      (cb as HTMLInputElement).checked = (t.apartment_ids ?? []).includes((cb as HTMLInputElement).value);
    });
    document.getElementById('modal-edit')?.classList.remove('hidden');
  }

  function confirmDelete(id, name) {
    document.getElementById('delete-id').value = id;
    document.getElementById('delete-name').textContent = `"${name}"`;
    document.getElementById('modal-delete')?.classList.remove('hidden');
  }

  async function copyTemplate(btn) {
    const content = btn.getAttribute('data-content');
    try {
      await navigator.clipboard.writeText(content);
      const original = btn.innerHTML;
      btn.innerHTML = `<svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg> Kopirano!`;
      btn.classList.replace('bg-blue-600', 'bg-green-600');
      btn.classList.replace('hover:bg-blue-700', 'hover:bg-green-700');
      setTimeout(() => {
        btn.innerHTML = original;
        btn.classList.replace('bg-green-600', 'bg-blue-600');
        btn.classList.replace('hover:bg-green-700', 'hover:bg-blue-700');
      }, 2000);
    } catch {
      showToast('Kopiranje nije uspjelo.', 'error');
    }
  }

  // Skupi checkboxe u hidden input prije submita
  document.getElementById('form-add')?.addEventListener('submit', () => {
    const ids = [...document.querySelectorAll('.add-apt-cb:checked')].map((cb) => (cb as HTMLInputElement).value);
    document.getElementById('add-apartment_ids').value = JSON.stringify(ids);
  });

  document.getElementById('form-edit')?.addEventListener('submit', () => {
    const ids = [...document.querySelectorAll('.edit-apt-cb:checked')].map((cb) => (cb as HTMLInputElement).value);
    document.getElementById('edit-apartment_ids').value = JSON.stringify(ids);
  });

  function applyFilters() {
    const search = (document.getElementById('search-input') as HTMLInputElement)?.value.toLowerCase().trim() ?? '';
    const aptId = (document.getElementById('apt-filter') as HTMLSelectElement)?.value ?? '';

    const cards = document.querySelectorAll<HTMLElement>('.template-card');
    let visible = 0;

    cards.forEach((card) => {
      const name = card.dataset.name ?? '';
      const content = card.dataset.content ?? '';
      const aptIds: string[] = JSON.parse(card.dataset.aptIds ?? '[]');

      const matchSearch = !search || name.includes(search) || content.includes(search);
      const matchApt = !aptId || aptIds.includes(aptId);

      if (matchSearch && matchApt) {
        card.classList.remove('hidden');
        visible++;
      } else {
        card.classList.add('hidden');
      }
    });

    // Ažuriraj brojač
    const total = cards.length;
    const countEl = document.getElementById('template-count');
    if (countEl) {
      const n = visible;
      countEl.textContent = `${n} predložak${n === 1 ? '' : n < 5 ? 'a' : 'a'}${visible < total ? ` (od ${total})` : ''}`;
    }

    // Prikaži/sakrij "nema rezultata"
    document.getElementById('no-results')?.classList.toggle('hidden', visible > 0);
    document.getElementById('template-grid')?.classList.toggle('hidden', visible === 0);
  }

  function clearFilters() {
    const searchEl = document.getElementById('search-input') as HTMLInputElement;
    const aptEl = document.getElementById('apt-filter') as HTMLSelectElement;
    if (searchEl) searchEl.value = '';
    if (aptEl) aptEl.value = '';
    applyFilters();
  }

  window.applyFilters = applyFilters;
  window.clearFilters = clearFilters;
  window.closeModalOnOverlay = closeModalOnOverlay;
  window.openAddModal = openAddModal;
  window.openEditModal = openEditModal;
  window.confirmDelete = confirmDelete;
  window.copyTemplate = copyTemplate;

  const _params = new URLSearchParams(window.location.search);
  const _success = _params.get('success');
  const _error = _params.get('error');
  const _msgs = { created: 'Predložak je uspješno kreiran.', updated: 'Predložak je uspješno ažuriran.', deleted: 'Predložak je uspješno obrisan.' };
  if (_success && _msgs[_success]) showToast(_msgs[_success]);
  if (_error) showToast(decodeURIComponent(_error), 'error');
  if (_success || _error) {
    const _url = new URL(window.location.href);
    _url.searchParams.delete('success'); _url.searchParams.delete('error');
    history.replaceState({}, '', _url.toString());
  }
</script>
