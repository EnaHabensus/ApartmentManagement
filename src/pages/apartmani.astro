---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;
const adminSupabase = createSupabaseAdminClient();

const APT_COLORS = [
  { hex: '#3B82F6', label: 'Plava' },
  { hex: '#8B5CF6', label: 'Ljubičasta' },
  { hex: '#10B981', label: 'Zelena' },
  { hex: '#F59E0B', label: 'Narančasta' },
  { hex: '#EC4899', label: 'Roza' },
  { hex: '#EF4444', label: 'Crvena' },
  { hex: '#14B8A6', label: 'Tirkizna' },
  { hex: '#6366F1', label: 'Indigo' },
  { hex: '#F97316', label: 'Koraljna' },
  { hex: '#84CC16', label: 'Limeta' },
];

// Dohvati sve apartmane korisnika (admin + staff)
const { data: apartmentUsers } = await supabase
  .from('apartment_users')
  .select('role, apartments(*)')
  .eq('user_id', user.id);

const adminApartmentUsers = (apartmentUsers ?? []).filter((au) => au.role === 'admin');
const apartments = adminApartmentUsers
  .map((au) => au.apartments)
  .filter((a) => a && !(a as any).is_deleted);

const staffApartmentUsers = (apartmentUsers ?? []).filter((au) => au.role === 'staff');
const staffApartments = staffApartmentUsers
  .map((au) => au.apartments)
  .filter((a) => a && !(a as any).is_deleted);

// Dohvati pending pozivnice za ovog korisnika
const { data: rawPendingInvites } = await adminSupabase
  .from('invite_tokens')
  .select('*')
  .eq('email', profile.email)
  .is('accepted_at', null)
  .gt('expires_at', new Date().toISOString());

// Za svaku pozivnicu dohvati nazive apartmana i ime onoga koji je pozvao
const pendingInvites = await Promise.all(
  (rawPendingInvites ?? []).map(async (invite: any) => {
    const { data: apts } = await adminSupabase
      .from('apartments')
      .select('name')
      .in('id', invite.apartment_ids);
    const { data: inviter } = await adminSupabase
      .from('profiles')
      .select('full_name')
      .eq('id', invite.invited_by)
      .single();
    return {
      id: invite.id as string,
      apartmentNames: (apts ?? []).map((a: any) => a.name).join(', '),
      inviterName: inviter?.full_name ?? 'Admin',
      role: invite.role as string,
    };
  })
);

const hasAnyEntries = (apartmentUsers ?? []).length > 0;
const isAdmin = adminApartmentUsers.length > 0 || !hasAnyEntries;
const success = Astro.url.searchParams.get('success');
const error = Astro.url.searchParams.get('error');
---

<AppLayout title="Apartmani" user={profile} isAdmin={true} activeRoute="/apartmani">
  <div class="p-6 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Apartmani</h1>
        <p class="text-gray-500 text-sm mt-1">{apartments.length} apartman{apartments.length === 1 ? '' : 'a'}</p>
      </div>
      <button
        onclick="document.getElementById('modal-add').classList.remove('hidden')"
        class="btn-primary"
      >
        + Dodaj apartman
      </button>
    </div>

    <!-- Pozivnice na čekanju -->
    {pendingInvites.length > 0 && (
      <div class="mb-8">
        <h2 class="text-lg font-semibold text-gray-900 mb-3">Pozivnice na čekanju</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {pendingInvites.map((invite) => (
            <div class="card p-5 border-l-4 border-blue-500">
              <div class="flex items-start gap-3 mb-4">
                <div class="h-10 w-10 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
                  <svg class="h-5 w-5 text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                  </svg>
                </div>
                <div class="min-w-0">
                  <h3 class="font-semibold text-gray-900 truncate">{invite.apartmentNames}</h3>
                  <p class="text-sm text-gray-500">Poziva: {invite.inviterName}</p>
                  <span class="inline-block mt-1 text-xs bg-blue-100 text-blue-700 px-2 py-0.5 rounded">Osoblje</span>
                </div>
              </div>
              <div class="flex gap-2">
                <button
                  onclick={`respondToInvite('${invite.id}', 'accept', event)`}
                  class="btn-primary text-sm flex-1"
                >
                  Prihvati
                </button>
                <button
                  onclick={`respondToInvite('${invite.id}', 'decline', event)`}
                  class="btn-secondary text-sm flex-1 !text-red-600 hover:!bg-red-50"
                >
                  Odbij
                </button>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

    <!-- Moji apartmani (admin) -->
    {(apartments.length > 0 || pendingInvites.length === 0) && (
      <div class={staffApartments.length > 0 || pendingInvites.length > 0 ? 'mb-8' : ''}>
        {(staffApartments.length > 0 || pendingInvites.length > 0) && (
          <h2 class="text-lg font-semibold text-gray-900 mb-3">Moji apartmani</h2>
        )}
        {apartments.length === 0 ? (
          <div class="card p-12 text-center">
            <div class="text-gray-400 mb-4">
              <svg class="mx-auto h-12 w-12" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h3 class="text-lg font-medium text-gray-900 mb-2">Nema apartmana</h3>
            <p class="text-gray-500 mb-6">Dodajte prvi apartman da biste počeli koristiti aplikaciju.</p>
            <button
              onclick="document.getElementById('modal-add').classList.remove('hidden')"
              class="btn-primary"
            >
              + Dodaj apartman
            </button>
          </div>
        ) : (
          <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
            {apartments.map((apt) => (
              <div class="card p-5 hover:shadow-md transition-shadow">
                <div class="flex items-start justify-between mb-3">
                  <div class="h-10 w-10 rounded-lg bg-blue-50 flex items-center justify-center flex-shrink-0">
                    <span class="text-blue-600 font-bold text-sm">{(apt as any).name.slice(0, 2).toUpperCase()}</span>
                  </div>
                  <div class="flex gap-1">
                    <button
                      onclick={`openEditModal(${JSON.stringify(apt)})`}
                      class="btn-ghost text-xs px-2 py-1"
                    >
                      Uredi
                    </button>
                    <button
                      onclick={`confirmDelete('${(apt as any).id}', '${(apt as any).name}')`}
                      class="btn-ghost text-xs px-2 py-1 text-red-500 hover:bg-red-50 hover:text-red-700"
                    >
                      Obriši
                    </button>
                  </div>
                </div>
                <h3 class="font-semibold text-gray-900 mb-1">{(apt as any).name}</h3>
                <p class="text-sm text-gray-500">{(apt as any).address}</p>
                <p class="text-sm text-gray-500">{(apt as any).postal_code} {(apt as any).city}, {(apt as any).country}</p>
                <div class="mt-3 pt-3 border-t border-gray-100 flex gap-4 text-xs text-gray-500">
                  <span>Check-in: {(apt as any).check_in_time}</span>
                  <span>Check-out: {(apt as any).check_out_time}</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    )}

    <!-- Apartmani na kojima radim (staff) -->
    {staffApartments.length > 0 && (
      <div>
        <h2 class="text-lg font-semibold text-gray-900 mb-3">Apartmani na kojima radim</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
          {staffApartments.map((apt) => (
            <div class="card p-5">
              <div class="flex items-start justify-between mb-3">
                <div class="h-10 w-10 rounded-lg bg-gray-100 flex items-center justify-center flex-shrink-0">
                  <span class="text-gray-500 font-bold text-sm">{(apt as any).name.slice(0, 2).toUpperCase()}</span>
                </div>
                <span class="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-full">Osoblje</span>
              </div>
              <h3 class="font-semibold text-gray-900 mb-1">{(apt as any).name}</h3>
              <p class="text-sm text-gray-500">{(apt as any).address}</p>
              <p class="text-sm text-gray-500">{(apt as any).postal_code} {(apt as any).city}, {(apt as any).country}</p>
              <div class="mt-3 pt-3 border-t border-gray-100 flex gap-4 text-xs text-gray-500">
                <span>Check-in: {(apt as any).check_in_time}</span>
                <span>Check-out: {(apt as any).check_out_time}</span>
              </div>
            </div>
          ))}
        </div>
      </div>
    )}

  </div>

  <!-- Modal: Dodaj apartman -->
  <div id="modal-add" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-add')">
    <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Dodaj apartman</h2>
      </div>
      <form action="/api/apartmani/create" method="POST" class="p-6 space-y-5">
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="label">Naziv apartmana *</label>
            <input name="name" type="text" required class="input" placeholder="npr. Arena Pula" />
          </div>
          <div class="col-span-2">
            <label class="label">Adresa *</label>
            <input name="address" type="text" required class="input" placeholder="Ulica i broj" />
          </div>
          <div>
            <label class="label">Poštanski broj *</label>
            <input name="postal_code" type="text" required class="input" placeholder="52100" />
          </div>
          <div>
            <label class="label">Grad *</label>
            <input name="city" type="text" required class="input" placeholder="Pula" />
          </div>
          <div class="col-span-2">
            <label class="label">Država *</label>
            <input name="country" type="text" required class="input" value="Hrvatska" />
          </div>
          <div>
            <label class="label">Check-in *</label>
            <input name="check_in_time" type="time" required class="input" value="14:00" />
          </div>
          <div>
            <label class="label">Check-out *</label>
            <input name="check_out_time" type="time" required class="input" value="10:00" />
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <h3 class="font-medium text-gray-900 mb-4">Podaci iznajmljivača</h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
              <label class="label">Ime i prezime *</label>
              <input name="owner_name" type="text" required class="input" />
            </div>
            <div class="col-span-2">
              <label class="label">OIB (11 znamenki) *</label>
              <input name="owner_oib" type="text" required pattern="[0-9]{11}" class="input" placeholder="12345678901" />
            </div>
            <div class="col-span-2">
              <label class="label">Adresa *</label>
              <input name="owner_address" type="text" required class="input" />
            </div>
            <div>
              <label class="label">Poštanski broj *</label>
              <input name="owner_postal_code" type="text" required class="input" />
            </div>
            <div>
              <label class="label">Grad *</label>
              <input name="owner_city" type="text" required class="input" />
            </div>
            <div class="col-span-2">
              <label class="label">Država *</label>
              <input name="owner_country" type="text" required class="input" value="Hrvatska" />
            </div>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <label class="label mb-2">Boja apartmana</label>
          <input type="hidden" name="color" id="add-color" value="#3B82F6" />
          <div class="flex flex-wrap gap-2">
            {APT_COLORS.map((c) => (
              <button
                type="button"
                title={c.label}
                onclick={`selectColor('add-color', '${c.hex}', this)`}
                class="color-swatch h-8 w-8 rounded-full border-2 border-transparent hover:scale-110 transition-transform"
                style={`background-color: ${c.hex}`}
                data-color={c.hex}
              ></button>
            ))}
          </div>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" onclick="document.getElementById('modal-add').classList.add('hidden')" class="btn-secondary">
            Odustani
          </button>
          <button type="submit" class="btn-primary">Spremi</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Uredi apartman -->
  <div id="modal-edit" class="hidden modal-overlay" onclick="closeModalOnOverlay(event, 'modal-edit')">
    <div class="modal-content max-h-[90vh] overflow-y-auto" onclick="event.stopPropagation()">
      <div class="p-6 border-b border-gray-100">
        <h2 class="text-lg font-semibold text-gray-900">Uredi apartman</h2>
      </div>
      <form id="form-edit" action="/api/apartmani/update" method="POST" class="p-6 space-y-5">
        <input type="hidden" name="id" id="edit-id" />
        <div class="grid grid-cols-2 gap-4">
          <div class="col-span-2">
            <label class="label">Naziv apartmana *</label>
            <input id="edit-name" name="name" type="text" required class="input" />
          </div>
          <div class="col-span-2">
            <label class="label">Adresa *</label>
            <input id="edit-address" name="address" type="text" required class="input" />
          </div>
          <div>
            <label class="label">Poštanski broj *</label>
            <input id="edit-postal_code" name="postal_code" type="text" required class="input" />
          </div>
          <div>
            <label class="label">Grad *</label>
            <input id="edit-city" name="city" type="text" required class="input" />
          </div>
          <div class="col-span-2">
            <label class="label">Država *</label>
            <input id="edit-country" name="country" type="text" required class="input" />
          </div>
          <div>
            <label class="label">Check-in *</label>
            <input id="edit-check_in_time" name="check_in_time" type="time" required class="input" />
          </div>
          <div>
            <label class="label">Check-out *</label>
            <input id="edit-check_out_time" name="check_out_time" type="time" required class="input" />
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <h3 class="font-medium text-gray-900 mb-4">Podaci iznajmljivača</h3>
          <div class="grid grid-cols-2 gap-4">
            <div class="col-span-2">
              <label class="label">Ime i prezime *</label>
              <input id="edit-owner_name" name="owner_name" type="text" required class="input" />
            </div>
            <div class="col-span-2">
              <label class="label">OIB *</label>
              <input id="edit-owner_oib" name="owner_oib" type="text" required pattern="[0-9]{11}" class="input" />
            </div>
            <div class="col-span-2">
              <label class="label">Adresa *</label>
              <input id="edit-owner_address" name="owner_address" type="text" required class="input" />
            </div>
            <div>
              <label class="label">Poštanski broj *</label>
              <input id="edit-owner_postal_code" name="owner_postal_code" type="text" required class="input" />
            </div>
            <div>
              <label class="label">Grad *</label>
              <input id="edit-owner_city" name="owner_city" type="text" required class="input" />
            </div>
            <div class="col-span-2">
              <label class="label">Država *</label>
              <input id="edit-owner_country" name="owner_country" type="text" required class="input" />
            </div>
          </div>
        </div>

        <div class="border-t border-gray-100 pt-5">
          <label class="label mb-2">Boja apartmana</label>
          <input type="hidden" name="color" id="edit-color" value="#3B82F6" />
          <div class="flex flex-wrap gap-2">
            {APT_COLORS.map((c) => (
              <button
                type="button"
                title={c.label}
                onclick={`selectColor('edit-color', '${c.hex}', this)`}
                class="color-swatch h-8 w-8 rounded-full border-2 border-transparent hover:scale-110 transition-transform"
                style={`background-color: ${c.hex}`}
                data-color={c.hex}
              ></button>
            ))}
          </div>
        </div>

        <div class="flex justify-end gap-3 pt-2">
          <button type="button" onclick="document.getElementById('modal-edit').classList.add('hidden')" class="btn-secondary">
            Odustani
          </button>
          <button type="submit" class="btn-primary">Spremi promjene</button>
        </div>
      </form>
    </div>
  </div>

  <!-- Modal: Potvrda brisanja -->
  <div id="modal-delete" class="hidden modal-overlay">
    <div class="modal-content p-6" onclick="event.stopPropagation()">
      <h2 class="text-lg font-semibold text-gray-900 mb-2">Obriši apartman</h2>
      <p class="text-gray-600 mb-2">Jeste li sigurni da želite obrisati <strong id="delete-name"></strong>?</p>
      <p class="text-sm text-red-600 mb-6">Sve rezervacije bit će označene kao Otkazane. Ova akcija se ne može poništiti.</p>
      <form action="/api/apartmani/delete" method="POST">
        <input type="hidden" name="id" id="delete-id" />
        <div class="flex justify-end gap-3">
          <button type="button" onclick="document.getElementById('modal-delete').classList.add('hidden')" class="btn-secondary">
            Odustani
          </button>
          <button type="submit" class="btn-danger">Obriši</button>
        </div>
      </form>
    </div>
  </div>
</AppLayout>

<script>
  function closeModalOnOverlay(event: MouseEvent, id: string) {
    if (event.target === document.getElementById(id)) {
      document.getElementById(id)?.classList.add('hidden');
    }
  }

  function selectColor(inputId: string, hex: string, btn: HTMLElement) {
    (document.getElementById(inputId) as HTMLInputElement).value = hex;
    // Reset svi gumbi u istom containeru
    btn.closest('.flex')?.querySelectorAll('.color-swatch').forEach((b) => {
      (b as HTMLElement).style.borderColor = 'transparent';
      (b as HTMLElement).style.boxShadow = 'none';
    });
    btn.style.borderColor = '#1f2937';
    btn.style.boxShadow = '0 0 0 2px white, 0 0 0 4px ' + hex;
  }

  function openEditModal(apt: Record<string, string>) {
    const fields = ['id','name','address','postal_code','city','country','check_in_time','check_out_time',
                    'owner_name','owner_oib','owner_address','owner_postal_code','owner_city','owner_country'];
    fields.forEach((f) => {
      const el = document.getElementById(`edit-${f}`) as HTMLInputElement;
      if (el) el.value = apt[f] ?? '';
    });
    // Postavi boju
    const color = apt['color'] || '#3B82F6';
    (document.getElementById('edit-color') as HTMLInputElement).value = color;
    document.querySelectorAll('#modal-edit .color-swatch').forEach((b) => {
      const btn = b as HTMLElement;
      btn.style.borderColor = 'transparent';
      btn.style.boxShadow = 'none';
      if (btn.dataset.color === color) {
        btn.style.borderColor = '#1f2937';
        btn.style.boxShadow = '0 0 0 2px white, 0 0 0 4px ' + color;
      }
    });
    document.getElementById('modal-edit')?.classList.remove('hidden');
  }

  function confirmDelete(id: string, name: string) {
    (document.getElementById('delete-id') as HTMLInputElement).value = id;
    document.getElementById('delete-name')!.textContent = name;
    document.getElementById('modal-delete')?.classList.remove('hidden');
  }

  (window as any).closeModalOnOverlay = closeModalOnOverlay;
  (window as any).openEditModal = openEditModal;
  (window as any).confirmDelete = confirmDelete;
  (window as any).selectColor = selectColor;

  async function respondToInvite(tokenId: string, action: string, event: MouseEvent) {
    const btn = event.currentTarget as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = action === 'accept' ? 'Prihvaćam...' : 'Odbijam...';
    try {
      const res = await fetch('/api/invite/respond', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ token_id: tokenId, action }),
      });
      const data = await res.json();
      if (!res.ok) {
        showToast(data.error ?? 'Greška', 'error');
        btn.disabled = false;
        btn.textContent = action === 'accept' ? 'Prihvati' : 'Odbij';
        return;
      }
      showToast(action === 'accept' ? 'Pozivnica prihvaćena!' : 'Pozivnica odbijena.', action === 'accept' ? 'success' : 'error');
      setTimeout(() => window.location.reload(), 1200);
    } catch {
      showToast('Greška pri odgovoru na pozivnicu', 'error');
      btn.disabled = false;
    }
  }
  (window as any).respondToInvite = respondToInvite;

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    let toast = document.getElementById('_toast');
    if (!toast) {
      toast = document.createElement('div');
      toast.id = '_toast';
      document.body.appendChild(toast);
    }
    toast.textContent = message;
    toast.className = `fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg ${type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'}`;
    setTimeout(() => toast!.remove(), 3500);
  }

  const _p = new URLSearchParams(window.location.search);
  const _s = _p.get('success'), _e = _p.get('error');
  const _m: Record<string, string> = { created: 'Apartman je uspješno kreiran.', updated: 'Apartman je uspješno ažuriran.', deleted: 'Apartman je uspješno obrisan.' };
  if (_s && _m[_s]) showToast(_m[_s], 'success');
  if (_e) showToast(decodeURIComponent(_e), 'error');
  if (_s || _e) {
    const _url = new URL(window.location.href);
    _url.searchParams.delete('success'); _url.searchParams.delete('error');
    history.replaceState({}, '', _url.toString());
  }
</script>
