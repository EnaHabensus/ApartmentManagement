---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;
const adminSupabase = createSupabaseAdminClient();

// Samo admin
const { data: myApartmentUsers } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id, role')
  .eq('user_id', user.id);

const adminApartmentIds = (myApartmentUsers ?? []).filter((au) => au.role === 'admin').map((au) => au.apartment_id);

const { data: apartmentsData } = await adminSupabase
  .from('apartments')
  .select('id, name, color')
  .in('id', adminApartmentIds)
  .eq('is_deleted', false);

const allApartments = apartmentsData ?? [];
const aptMap = new Map(allApartments.map((a) => [a.id, a.name]));
const aptColorMap = new Map(allApartments.map((a) => [a.id, (a as any).color as string ?? '#3B82F6']));

// URL parametri
const period = Astro.url.searchParams.get('period') ?? 'all';
const filterApartmentId = Astro.url.searchParams.get('apartment_id') ?? '';
const dateFrom = Astro.url.searchParams.get('date_from') ?? '';
const dateTo = Astro.url.searchParams.get('date_to') ?? '';

// Izračunaj date range
const TZ = 'Europe/Zagreb';
const today = new Date(new Date().toLocaleDateString('sv-SE', { timeZone: TZ }) + 'T00:00:00');
let qFrom: string | null = null;
let qTo: string | null = null;

if (period === 'this_month') {
  qFrom = new Date(today.getFullYear(), today.getMonth(), 1).toLocaleDateString('sv-SE', { timeZone: TZ });
  qTo = new Date(today.getFullYear(), today.getMonth() + 1, 0).toLocaleDateString('sv-SE', { timeZone: TZ });
} else if (period === 'last_month') {
  qFrom = new Date(today.getFullYear(), today.getMonth() - 1, 1).toLocaleDateString('sv-SE', { timeZone: TZ });
  qTo = new Date(today.getFullYear(), today.getMonth(), 0).toLocaleDateString('sv-SE', { timeZone: TZ });
} else if (period === 'custom') {
  qFrom = dateFrom || null;
  qTo = dateTo || null;
}

const aptIds = filterApartmentId ? [filterApartmentId] : adminApartmentIds;

let rezQuery = adminSupabase
  .from('reservations')
  .select('id, guest_name, check_in, check_out, amount_gross, commission, is_paid, apartment_id')
  .in('apartment_id', aptIds.length > 0 ? aptIds : ['none'])
  .eq('status', 'active')
  .order('check_in', { ascending: false });

if (qFrom) rezQuery = rezQuery.gte('check_in', qFrom);
if (qTo) rezQuery = rezQuery.lte('check_in', qTo);

const { data: rezervacije } = await rezQuery;
const rez = rezervacije ?? [];

// KPI
const bruto = rez.reduce((s, r) => s + (r.amount_gross ?? 0), 0);
const provizija = rez.reduce((s, r) => s + (r.commission ?? 0), 0);
const neto = rez.reduce((s, r) => s + ((r.amount_gross ?? 0) - (r.commission ?? 0)), 0);
const zaprimljeno = rez.filter((r) => r.is_paid).reduce((s, r) => s + ((r.amount_gross ?? 0) - (r.commission ?? 0)), 0);

function formatDate(d: string): string {
  const [y, m, day] = d.split('-');
  return `${day}.${m}.${y}`;
}

function formatEur(n: number): string {
  return new Intl.NumberFormat('hr-HR', { style: 'currency', currency: 'EUR' }).format(n);
}

function calcNocenja(checkIn: string, checkOut: string): number {
  return Math.round((new Date(checkOut).getTime() - new Date(checkIn).getTime()) / 86400000);
}
---

<AppLayout title="Financije" user={profile} isAdmin={true} activeRoute="/financije">
  <div class="p-4 md:p-6 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-3 mb-6">
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-gray-900">Financije</h1>
        <p class="text-gray-500 text-sm mt-0.5">{rez.length} rezervacij{rez.length === 1 ? 'a' : rez.length < 5 ? 'e' : 'a'}</p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <!-- Filter perioda -->
        <form method="GET" id="form-period">
          <input type="hidden" name="apartment_id" value={filterApartmentId} />
          <select
            name="period"
            onchange="document.getElementById('form-period').submit()"
            class="input text-sm w-auto"
          >
            <option value="all" selected={period === 'all'}>Od početka</option>
            <option value="this_month" selected={period === 'this_month'}>Ovaj mjesec</option>
            <option value="last_month" selected={period === 'last_month'}>Prethodni mjesec</option>
            <option value="custom" selected={period === 'custom'}>Po datumu</option>
          </select>
        </form>

        <!-- Custom datumi (vidljivi samo kad period=custom) -->
        {period === 'custom' && (
          <form method="GET" id="form-custom" class="flex items-center gap-2">
            <input type="hidden" name="period" value="custom" />
            <input type="hidden" name="apartment_id" value={filterApartmentId} />
            <input name="date_from" type="date" value={dateFrom} class="input text-sm" />
            <input name="date_to" type="date" value={dateTo} class="input text-sm" />
            <button type="submit" class="btn-primary text-sm px-3">Primijeni</button>
          </form>
        )}

        <!-- Filter apartmana -->
        {allApartments.length > 1 && (
          <form method="GET" id="form-apt">
            <input type="hidden" name="period" value={period} />
            {period === 'custom' && <input type="hidden" name="date_from" value={dateFrom} />}
            {period === 'custom' && <input type="hidden" name="date_to" value={dateTo} />}
            <select
              name="apartment_id"
              onchange="document.getElementById('form-apt').submit()"
              class="input text-sm w-auto"
            >
              <option value="">Svi apartmani</option>
              {allApartments.map((apt) => (
                <option value={apt.id} selected={filterApartmentId === apt.id}>{apt.name}</option>
              ))}
            </select>
          </form>
        )}
      </div>
    </div>

    <!-- KPI kartice -->
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-6">
      <div class="card p-4">
        <p class="text-xs font-medium text-gray-500 mb-1">Bruto (EUR)</p>
        <p class="text-xl font-bold text-gray-900">{formatEur(bruto)}</p>
      </div>
      <div class="card p-4">
        <p class="text-xs font-medium text-gray-500 mb-1">Neto (EUR)</p>
        <p class="text-xl font-bold text-gray-900">{formatEur(neto)}</p>
      </div>
      <div class="card p-4">
        <p class="text-xs font-medium text-gray-500 mb-1">Provizija (EUR)</p>
        <p class="text-xl font-bold text-gray-900">{formatEur(provizija)}</p>
      </div>
      <div class="card p-4">
        <p class="text-xs font-medium text-gray-500 mb-1">Zaprimljeno (EUR)</p>
        <p class="text-xl font-bold text-green-600" id="kpi-zaprimljeno">{formatEur(zaprimljeno)}</p>
      </div>
    </div>

    <!-- Prazno stanje -->
    {rez.length === 0 ? (
      <div class="card p-12 text-center">
        <p class="text-gray-400">Nema financijskih podataka za odabrani period.</p>
      </div>
    ) : (
      <>
        <!-- Mobile: kartice -->
        <div class="md:hidden space-y-3">
          {rez.map((r) => {
            const n = (r.amount_gross ?? 0) - (r.commission ?? 0);
            const color = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
            const aptName = aptMap.get(r.apartment_id) ?? '—';
            const nocenja = calcNocenja(r.check_in, r.check_out);
            const finData = JSON.stringify({
              id: r.id, guest_name: r.guest_name, apartment_id: r.apartment_id,
              apt_name: aptName, apt_color: color,
              check_in: r.check_in, check_out: r.check_out, nocenja,
              amount_gross: r.amount_gross ?? 0, commission: r.commission ?? 0, neto: n,
              is_paid: !!r.is_paid,
            });
            return (
              <div
                class="card p-4 cursor-pointer active:bg-slate-50 transition-colors"
                id={`fin-card-${r.id}`}
                data-fin={finData}
                data-neto={n}
                data-paid={r.is_paid ? '1' : '0'}
                onclick="openFinDrawer(this)"
              >
                {/* Redak 1: apt badge */}
                <span
                  class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium whitespace-nowrap mb-1.5"
                  style={`background-color:${color}20;color:${color};box-shadow:inset 0 0 0 1px ${color}40`}
                >{aptName}</span>

                {/* Redak 2: ime gosta */}
                <p class="font-semibold text-slate-900 truncate mb-1">{r.guest_name}</p>

                {/* Redak 3: datumi + noćenja */}
                <p class="text-sm text-slate-500 mb-3">
                  {formatDate(r.check_in)} → {formatDate(r.check_out)}
                  <span class="text-slate-400 ml-1">· {nocenja === 1 ? '1 noć' : `${nocenja} noćenja`}</span>
                </p>

                {/* Redak 4: toggle isplate */}
                <div
                  class="flex items-center gap-3 mb-3"
                  onclick="event.stopPropagation()"
                >
                  <button
                    id={`card-paid-btn-${r.id}`}
                    onclick={`togglePaid('${r.id}', ${r.is_paid})`}
                    class={`h-8 w-8 rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-colors ${r.is_paid ? 'bg-green-500 border-green-500 text-white' : 'border-slate-300 text-transparent'}`}
                  >
                    <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                      <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
                    </svg>
                  </button>
                  <span class="text-sm text-slate-700">Isplata zaprimljena</span>
                </div>

                {/* Redak 5: neto + detalji */}
                <div class="flex items-center justify-between">
                  <span class="font-bold text-slate-900 text-sm">{formatEur(n)}</span>
                  <div class="flex items-center gap-0.5 text-blue-600">
                    <span class="text-xs font-medium">Detalji</span>
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
                  </div>
                </div>
              </div>
            );
          })}
        </div>

        <!-- Desktop: tablica -->
        <div class="hidden md:block overflow-x-auto rounded-xl border border-gray-200 bg-white shadow-sm">
          <table class="text-sm" style="min-width: 800px; width: 100%;">
            <thead>
              <tr>
                <th class="table-head px-4 py-3 text-left whitespace-nowrap">Gost</th>
                <th class="table-head px-4 py-3 text-left">Apartman</th>
                <th class="table-head px-4 py-3 text-left whitespace-nowrap">Check-in</th>
                <th class="table-head px-4 py-3 text-left whitespace-nowrap">Check-out</th>
                <th class="table-head px-4 py-3 text-right whitespace-nowrap">Bruto (EUR)</th>
                <th class="table-head px-4 py-3 text-right whitespace-nowrap">Provizija (EUR)</th>
                <th class="table-head px-4 py-3 text-right whitespace-nowrap">Neto (EUR)</th>
                <th class="table-head px-4 py-3 text-center whitespace-nowrap">Isplata zaprimljena</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {rez.map((r) => {
                const n = (r.amount_gross ?? 0) - (r.commission ?? 0);
                const color = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
                return (
                  <tr class="table-row" id={`row-${r.id}`} data-neto={n} data-paid={r.is_paid ? '1' : '0'}>
                    <td class="table-cell px-4 py-3 font-medium text-gray-900 whitespace-nowrap">{r.guest_name}</td>
                    <td class="table-cell px-4 py-3">
                      <span
                        class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium whitespace-nowrap"
                        style={`background-color: ${color}20; color: ${color}; box-shadow: inset 0 0 0 1px ${color}40`}
                      >
                        {aptMap.get(r.apartment_id) ?? '—'}
                      </span>
                    </td>
                    <td class="table-cell px-4 py-3 text-gray-700 whitespace-nowrap">{formatDate(r.check_in)}</td>
                    <td class="table-cell px-4 py-3 text-gray-700 whitespace-nowrap">{formatDate(r.check_out)}</td>
                    <td class="table-cell px-4 py-3 text-right text-gray-700">{formatEur(r.amount_gross ?? 0)}</td>
                    <td class="table-cell px-4 py-3 text-right text-gray-500">{formatEur(r.commission ?? 0)}</td>
                    <td class="table-cell px-4 py-3 text-right font-semibold text-gray-900">{formatEur(n)}</td>
                    <td class="table-cell px-4 py-3 text-center">
                      <button
                        onclick={`togglePaid('${r.id}', ${r.is_paid})`}
                        class={`h-6 w-6 rounded-full border-2 flex items-center justify-center mx-auto transition-colors ${r.is_paid ? 'bg-green-500 border-green-500 text-white' : 'border-gray-300 text-transparent hover:border-gray-400'}`}
                        title={r.is_paid ? 'Plaćeno' : 'Nije plaćeno'}
                      >
                        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                        </svg>
                      </button>
                    </td>
                  </tr>
                );
              })}
            </tbody>
            <tfoot class="border-t-2 border-gray-200 bg-gray-50">
              <tr>
                <td class="px-4 py-3 text-sm font-semibold text-gray-700" colspan="4">Ukupno ({rez.length})</td>
                <td class="px-4 py-3 text-right text-sm font-semibold text-gray-900">{formatEur(bruto)}</td>
                <td class="px-4 py-3 text-right text-sm font-semibold text-gray-500">{formatEur(provizija)}</td>
                <td class="px-4 py-3 text-right text-sm font-semibold text-gray-900">{formatEur(neto)}</td>
                <td class="px-4 py-3 text-center text-sm font-semibold text-green-600" id="footer-zaprimljeno">{formatEur(zaprimljeno)}</td>
              </tr>
            </tfoot>
          </table>
        </div>
      </>
    )}
  </div>

  <!-- Bottom drawer — mobile only -->
  <div
    id="fin-drawer"
    class="fixed inset-x-0 bottom-0 z-50 bg-white rounded-t-2xl shadow-2xl translate-y-full transition-transform duration-300 ease-out md:hidden flex flex-col"
    style="max-height: 90dvh;"
  >
    <div class="flex-shrink-0 relative flex items-center justify-center px-4 pt-3 pb-3 border-b border-slate-100">
      <div class="w-10 h-1 rounded-full bg-slate-200"></div>
      <button
        onclick="closeFinDrawer()"
        class="absolute right-3 p-1.5 rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>
    <div id="fin-drawer-body" class="flex-1 overflow-y-auto px-4 pt-4 pb-10"></div>
  </div>
  <div id="fin-drawer-overlay" class="hidden fixed inset-0 z-40 bg-black/40 md:hidden" onclick="closeFinDrawer()"></div>

  <div id="toast" class="hidden fixed bottom-4 right-4 z-[60] rounded-lg px-4 py-3 text-sm font-medium shadow-lg"></div>
  </div>

  <div id="toast" class="hidden fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg"></div>
</AppLayout>

<script>
  // ── Drawer ────────────────────────────────────────────────────────────────

  function fmtDate(d: string): string {
    const [y, m, day] = d.split('-'); return `${day}.${m}.${y}`;
  }
  function fmtEur(n: number): string {
    return new Intl.NumberFormat('hr-HR', { style: 'currency', currency: 'EUR' }).format(n);
  }

  function renderFinDrawerContent(r: any): string {
    const on  = 'bg-green-500 border-green-500 text-white';
    const off = 'border-slate-300 text-transparent';
    const nocLabel = r.nocenja === 1 ? '1 noć' : `${r.nocenja} noćenja`;
    return `
      <div class="flex items-start gap-2 mb-1">
        <h3 class="text-lg font-bold text-slate-900 flex-1">${r.guest_name}</h3>
      </div>
      <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium mb-5"
        style="background-color:${r.apt_color}20;color:${r.apt_color};box-shadow:inset 0 0 0 1px ${r.apt_color}40">
        ${r.apt_name}
      </span>

      <div class="grid grid-cols-3 gap-2 mb-3">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Check-in</p>
          <p class="text-sm font-semibold text-slate-800">${fmtDate(r.check_in)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Check-out</p>
          <p class="text-sm font-semibold text-slate-800">${fmtDate(r.check_out)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Noćenja</p>
          <p class="text-sm font-semibold text-slate-800">${nocLabel}</p>
        </div>
      </div>

      <div class="grid grid-cols-3 gap-2 mb-6">
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Bruto</p>
          <p class="text-sm font-semibold text-slate-800">${fmtEur(r.amount_gross)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Provizija</p>
          <p class="text-sm font-semibold text-slate-800">${fmtEur(r.commission)}</p>
        </div>
        <div class="bg-slate-50 rounded-xl p-3 text-center">
          <p class="text-xs text-slate-400 mb-1">Neto</p>
          <p class="text-sm font-bold text-slate-900">${fmtEur(r.neto)}</p>
        </div>
      </div>

      <div class="flex items-center gap-3 py-3 border-t border-slate-100">
        <button id="drawer-paid-btn" onclick="togglePaidFromDrawer('${r.id}', ${r.is_paid})"
          class="h-8 w-8 rounded-full border-2 flex items-center justify-center flex-shrink-0 transition-colors ${r.is_paid ? on : off}">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
            <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
          </svg>
        </button>
        <span class="text-sm text-slate-700">Isplata zaprimljena</span>
      </div>
    `;
  }

  function openFinDrawer(el: HTMLElement) {
    const r = JSON.parse((el as HTMLElement).dataset.fin || '{}');
    const body = document.getElementById('fin-drawer-body');
    if (body) body.innerHTML = renderFinDrawerContent(r);
    document.getElementById('fin-drawer')?.classList.remove('translate-y-full');
    document.getElementById('fin-drawer-overlay')?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeFinDrawer() {
    document.getElementById('fin-drawer')?.classList.add('translate-y-full');
    document.getElementById('fin-drawer-overlay')?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  function togglePaidFromDrawer(id: string, currentValue: boolean) {
    // Re-read current value from card so drawer stays in sync
    const card = document.getElementById(`fin-card-${id}`);
    const actualCurrent = card?.dataset.paid === '1';
    togglePaid(id, actualCurrent);
  }

  window.openFinDrawer  = openFinDrawer;
  window.closeFinDrawer = closeFinDrawer;
  window.togglePaidFromDrawer = togglePaidFromDrawer;

  // ── Toast ────────────────────────────────────────────────────────────────

  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.className = `fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg ${
      type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'
    }`;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  function fmt(n: number): string {
    return new Intl.NumberFormat('hr-HR', { style: 'currency', currency: 'EUR' }).format(n);
  }

  function recalcZaprimljeno() {
    let sum = 0;
    // Desktop rows
    document.querySelectorAll<HTMLElement>('tr[data-neto]').forEach((row) => {
      if (row.dataset.paid === '1') sum += parseFloat(row.dataset.neto ?? '0');
    });
    // Mobile cards (kad nema desktop tablice u viewu)
    if (sum === 0) {
      document.querySelectorAll<HTMLElement>('[id^="fin-card-"]').forEach((card) => {
        if (card.dataset.paid === '1') sum += parseFloat(card.dataset.neto ?? '0');
      });
    }
    const kpi = document.getElementById('kpi-zaprimljeno');
    const footer = document.getElementById('footer-zaprimljeno');
    if (kpi) kpi.textContent = fmt(sum);
    if (footer) footer.textContent = fmt(sum);
  }

  function updatePaidBtn(btn: HTMLButtonElement, newVal: boolean) {
    const on  = 'bg-green-500 border-green-500 text-white';
    const off = 'border-slate-300 text-transparent';
    btn.className = btn.className.replace(newVal ? off : on, '').trim() + ' ' + (newVal ? on : off);
  }

  async function togglePaid(id: string, currentValue: boolean) {
    try {
      const res = await fetch('/api/rezervacije/toggle-field', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ id, field: 'is_paid', value: !currentValue }),
      });
      const data = await res.json();
      if (res.ok && data.success) {
        const newVal = !currentValue;

        // Desktop row
        const row = document.getElementById(`row-${id}`);
        if (row) {
          row.dataset.paid = newVal ? '1' : '0';
          const btn = row.querySelector('button') as HTMLButtonElement | null;
          if (btn) {
            btn.setAttribute('onclick', `togglePaid('${id}', ${newVal})`);
            btn.title = newVal ? 'Plaćeno' : 'Nije plaćeno';
            const on = 'bg-green-500 border-green-500 text-white';
            const off = 'border-gray-300 text-transparent hover:border-gray-400';
            btn.className = btn.className.replace(newVal ? off : on, '').trim() + ' ' + (newVal ? on : off);
          }
        }

        // Mobile card
        const card = document.getElementById(`fin-card-${id}`);
        if (card) {
          card.dataset.paid = newVal ? '1' : '0';
          const cardBtn = document.getElementById(`card-paid-btn-${id}`) as HTMLButtonElement | null;
          if (cardBtn) {
            cardBtn.setAttribute('onclick', `togglePaid('${id}', ${newVal})`);
            updatePaidBtn(cardBtn, newVal);
          }
          // Ažuriraj data-fin
          try {
            const fd = JSON.parse(card.dataset.fin || '{}');
            fd.is_paid = newVal;
            card.dataset.fin = JSON.stringify(fd);
          } catch {}
        }

        // Drawer (ako je otvoren)
        const drawerBtn = document.getElementById('drawer-paid-btn') as HTMLButtonElement | null;
        if (drawerBtn) {
          drawerBtn.setAttribute('onclick', `togglePaidFromDrawer('${id}', ${newVal})`);
          updatePaidBtn(drawerBtn, newVal);
        }

        recalcZaprimljeno();
        showToast('Ažurirano.');
      } else {
        showToast(data.error ?? 'Greška pri ažuriranju.', 'error');
      }
    } catch {
      showToast('Greška pri slanju zahtjeva.', 'error');
    }
  }

  window.togglePaid = togglePaid;
</script>
