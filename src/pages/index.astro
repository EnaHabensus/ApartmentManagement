---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;
const adminSupabase = createSupabaseAdminClient();

// Provjeri ima li admin ulogu
const { data: adminApts } = await supabase
  .from('apartment_users')
  .select('apartment_id, apartments(id, name, is_deleted)')
  .eq('user_id', user.id)
  .eq('role', 'admin');

const apartments = adminApts
  ?.filter((au) => au.apartments && !au.apartments.is_deleted)
  .map((au) => au.apartments) ?? [];


const period = Astro.url.searchParams.get('period') || 'all';
const aptFilter = Astro.url.searchParams.get('apartment') || 'all';

const apartmentIds = apartments.map((a) => a.id);
const filteredAptIds = aptFilter === 'all' ? apartmentIds : [aptFilter];

// Boje i imena apartmana
const { data: aptDetailsData } = apartmentIds.length > 0
  ? await adminSupabase.from('apartments').select('id, name, color').in('id', apartmentIds)
  : { data: [] };
const aptColorMap = new Map((aptDetailsData ?? []).map((a) => [a.id, (a as any).color as string ?? '#3B82F6']));
const aptNameMap  = new Map((aptDetailsData ?? []).map((a) => [a.id, a.name]));

// Izračunaj datum range za period filter
// Koristimo Europe/Zagreb timezone da dobijemo ispravni današnji datum na serveru (UTC)
const TZ = 'Europe/Zagreb';
const todayStr = new Date().toLocaleDateString('sv-SE', { timeZone: TZ }); // YYYY-MM-DD
const today = new Date(todayStr + 'T00:00:00');

let dateFrom: string | null = null;
let dateTo: string | null = null;

if (period === 'this_month') {
  dateFrom = new Date(today.getFullYear(), today.getMonth(), 1).toLocaleDateString('sv-SE', { timeZone: TZ });
  dateTo = new Date(today.getFullYear(), today.getMonth() + 1, 0).toLocaleDateString('sv-SE', { timeZone: TZ });
} else if (period === 'last_month') {
  dateFrom = new Date(today.getFullYear(), today.getMonth() - 1, 1).toLocaleDateString('sv-SE', { timeZone: TZ });
  dateTo = new Date(today.getFullYear(), today.getMonth(), 0).toLocaleDateString('sv-SE', { timeZone: TZ });
}

// Dohvati rezervacije za KPI
let query = supabase
  .from('reservations')
  .select('*')
  .in('apartment_id', filteredAptIds.length ? filteredAptIds : ['none'])
  .eq('status', 'active');

if (dateFrom) query = query.gte('check_in', dateFrom);
if (dateTo) query = query.lte('check_in', dateTo);

const { data: reservations } = await query;

// KPI izračuni
const activeRez = reservations ?? [];
const bruttoSum = activeRez.reduce((s, r) => s + (r.amount_gross ?? 0), 0);
const nettoSum = activeRez.reduce((s, r) => s + ((r.amount_gross ?? 0) - (r.commission ?? 0)), 0);
const commissionSum = activeRez.reduce((s, r) => s + (r.commission ?? 0), 0);
const completedCount = activeRez.filter((r) => r.check_out <= todayStr).length;

// Popunjenost
let totalDays = 1;
let reservedDays = 0;
if (dateFrom && dateTo) {
  const from = new Date(dateFrom);
  const to = new Date(dateTo);
  totalDays = Math.max(1, (to.getTime() - from.getTime()) / 86400000 * (filteredAptIds.length || 1));
  reservedDays = activeRez.reduce((s, r) => {
    const ci = new Date(r.check_in);
    const co = new Date(r.check_out);
    return s + (co.getTime() - ci.getTime()) / 86400000;
  }, 0);
} else {
  totalDays = 365 * (filteredAptIds.length || 1);
  reservedDays = activeRez.reduce((s, r) => {
    const ci = new Date(r.check_in);
    const co = new Date(r.check_out);
    return s + (co.getTime() - ci.getTime()) / 86400000;
  }, 0);
}
const occupancy = Math.min(100, Math.round((reservedDays / totalDays) * 100));



// Check-out danas
const { data: checkoutsToday } = await adminSupabase
  .from('reservations')
  .select('id, guest_name, check_in, check_out, apartment_id')
  .in('apartment_id', filteredAptIds.length ? filteredAptIds : ['none'])
  .eq('check_out', todayStr)
  .eq('status', 'active')
  .order('check_out');

// Check-in danas
const { data: checkinsToday } = await adminSupabase
  .from('reservations')
  .select('id, guest_name, check_in, check_out, apartment_id')
  .in('apartment_id', filteredAptIds.length ? filteredAptIds : ['none'])
  .eq('check_in', todayStr)
  .eq('status', 'active')
  .order('check_in');

// Dohvati dodjele čišćenja za today's rez
const todayResIds = [
  ...(checkoutsToday ?? []).map((r) => r.id),
  ...(checkinsToday ?? []).map((r) => r.id),
];
const { data: cleaningRows } = todayResIds.length > 0
  ? await adminSupabase.from('reservation_cleaning').select('reservation_id, user_id').in('reservation_id', todayResIds)
  : { data: [] };
const cleanerUserIds = [...new Set((cleaningRows ?? []).map((c) => c.user_id))];
const { data: cleanerProfiles } = cleanerUserIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name').in('id', cleanerUserIds)
  : { data: [] };
const cleanerProfileMap = new Map((cleanerProfiles ?? []).map((p) => [p.id, p.full_name]));
const cleaningMap = new Map(
  (cleaningRows ?? []).map((c) => [c.reservation_id, { user_id: c.user_id, full_name: cleanerProfileMap.get(c.user_id) ?? '?' }])
);

// Dohvati korisnike po apartmanu za dropdown čišćenja
const { data: allAptUsers } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id, user_id')
  .in('apartment_id', apartmentIds.length ? apartmentIds : ['none']);
const aptUserIds = [...new Set((allAptUsers ?? []).map((u) => u.user_id))];
const { data: aptUserProfiles } = aptUserIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name').in('id', aptUserIds)
  : { data: [] };
const aptUserProfileMap = new Map((aptUserProfiles ?? []).map((p) => [p.id, p.full_name]));
const aptUsersForCleaningMap: Record<string, Array<{ user_id: string; full_name: string }>> = {};
for (const au of (allAptUsers ?? [])) {
  if (!aptUsersForCleaningMap[au.apartment_id]) aptUsersForCleaningMap[au.apartment_id] = [];
  aptUsersForCleaningMap[au.apartment_id].push({ user_id: au.user_id, full_name: aptUserProfileMap.get(au.user_id) ?? '?' });
}

// ── Grafovi ──────────────────────────────────────────────────────────────────

// Prihodi po načinu plaćanja (koristi iste filtrirane rezervacije)
const PAYMENT_LABELS: Record<string, string> = {
  credit_card: 'Kartica',
  cash: 'Gotovina',
  bank_transfer: 'Bankovni prijenos',
  airbnb: 'Airbnb',
  booking_com: 'Booking.com',
};
const PAYMENT_COLORS = ['#FF5A5F', '#003580', '#6366F1', '#10B981', '#F59E0B'];

const prihodiByType: Record<string, number> = {};
for (const r of activeRez) {
  const pt = r.payment_type || 'ostalo';
  prihodiByType[pt] = (prihodiByType[pt] ?? 0) + (r.amount_gross ?? 0);
}
const prihodiLabels = Object.keys(prihodiByType).map((k) => PAYMENT_LABELS[k] ?? k);
const prihodiValues = Object.values(prihodiByType);
const prihodiColors = Object.keys(prihodiByType).map((k, i) => PAYMENT_COLORS[Object.keys(PAYMENT_LABELS).indexOf(k)] ?? PAYMENT_COLORS[i % PAYMENT_COLORS.length]);

// Čišćenje po osobi (filtrirane rezervacije)
const { data: allRezForCleaning } = await adminSupabase
  .from('reservations')
  .select('id')
  .in('apartment_id', filteredAptIds.length ? filteredAptIds : ['none'])
  .eq('status', 'active');
const allRezIdList = (allRezForCleaning ?? []).map((r) => r.id);
const { data: allCleaningData } = allRezIdList.length > 0
  ? await adminSupabase.from('reservation_cleaning').select('user_id').in('reservation_id', allRezIdList)
  : { data: [] };
const cleaningCountMap: Record<string, number> = {};
for (const c of (allCleaningData ?? [])) {
  cleaningCountMap[c.user_id] = (cleaningCountMap[c.user_id] ?? 0) + 1;
}
const cleaningStatUserIds = Object.keys(cleaningCountMap);
const { data: cleaningStatProfiles } = cleaningStatUserIds.length > 0
  ? await adminSupabase.from('profiles').select('id, full_name').in('id', cleaningStatUserIds)
  : { data: [] };
const cleaningLabels = (cleaningStatProfiles ?? []).map((p) => p.full_name);
const cleaningValues = (cleaningStatProfiles ?? []).map((p) => cleaningCountMap[p.id] ?? 0);

function formatDate(d: string) {
  const [y, m, day] = d.split('-');
  return `${day}.${m}.${y}`;
}

function nights(ci: string, co: string) {
  return Math.round((new Date(co).getTime() - new Date(ci).getTime()) / 86400000);
}

---

<AppLayout title="Dashboard" user={profile} isAdmin={true} activeRoute="/">
  <div class="p-4 md:p-6 max-w-7xl mx-auto">
    <!-- Header -->
    <div class="flex flex-wrap items-start justify-between gap-3 mb-6">
      <div>
        <h1 class="text-xl md:text-2xl font-bold text-gray-900">Dashboard</h1>
        <p class="text-gray-500 text-sm mt-0.5">Pregled poslovanja</p>
      </div>

      <div class="flex flex-wrap items-center gap-2">
        <!-- Filter apartmana -->
        {apartments.length > 1 && (
          <form method="GET" id="form-apt">
            <select
              name="apartment"
              onchange="document.getElementById('form-apt').submit()"
              class="input text-sm w-auto"
            >
              <option value="all" selected={aptFilter === 'all'}>Svi apartmani</option>
              {apartments.map((a) => (
                <option value={a.id} selected={aptFilter === a.id}>{a.name}</option>
              ))}
            </select>
            <input type="hidden" name="period" value={period} />
          </form>
        )}

        <!-- Filter perioda -->
        <form method="GET" id="form-period">
          <select
            name="period"
            onchange="document.getElementById('form-period').submit()"
            class="input text-sm w-auto"
          >
            <option value="all" selected={period === 'all'}>Od početka</option>
            <option value="this_month" selected={period === 'this_month'}>Ovaj mjesec</option>
            <option value="last_month" selected={period === 'last_month'}>Prošli mjesec</option>
          </select>
          <input type="hidden" name="apartment" value={aptFilter} />
        </form>
      </div>
    </div>

    <!-- KPI kartice -->
    <div class="-mx-4 px-4 md:mx-0 md:px-0 mb-6 md:mb-8">
      <div class="flex overflow-x-auto gap-3 pb-1 snap-x snap-mandatory md:grid md:grid-cols-3 lg:grid-cols-6 md:gap-4 md:overflow-visible md:pb-0">
        {[
          { label: 'Bruto zarada', value: `€ ${bruttoSum.toFixed(2)}` },
          { label: 'Neto zarada', value: `€ ${nettoSum.toFixed(2)}` },
          { label: 'Provizija', value: `€ ${commissionSum.toFixed(2)}` },
          { label: 'Popunjenost', value: `${occupancy}%` },
          { label: 'Ukupno rezervacija', value: String(activeRez.length) },
          { label: 'Završene smjene', value: String(completedCount) },
        ].map(({ label, value }) => (
          <div class="card px-4 py-5 md:p-4 flex-shrink-0 w-44 md:w-auto snap-start">
            <p class="text-xs font-medium text-gray-500 mb-1.5 leading-tight">{label}</p>
            <p class="text-2xl md:text-xl font-bold text-gray-900 truncate">{value}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- Check-out i Check-in danas -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6 mt-4 md:mt-6">

      <!-- Check-out danas -->
      <div class="card">
        <div class="px-4 md:px-5 py-3 md:py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-900">Check-out danas</h2>
          <p class="text-xs text-gray-400 mt-0.5">{formatDate(todayStr)}</p>
        </div>
        {!checkoutsToday?.length ? (
          <div class="p-8 text-center text-gray-400 text-sm">Nema check-outova danas.</div>
        ) : (
          <>
            {/* Mobile card layout */}
            <div class="md:hidden divide-y divide-gray-100">
              {checkoutsToday.map((r) => {
                const cleaner = cleaningMap.get(r.id);
                const aptUsers = aptUsersForCleaningMap[r.apartment_id] ?? [];
                const aptColor = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
                const aptName  = aptNameMap.get(r.apartment_id) ?? '—';
                return (
                  <div class="px-4 py-3">
                    <div class="flex items-center justify-between gap-2 mb-1.5">
                      <span class="font-medium text-gray-900 text-sm truncate">{r.guest_name}</span>
                      <span class="text-xs text-gray-500 flex-shrink-0">{nights(r.check_in, r.check_out)} noć.</span>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium whitespace-nowrap"
                        style={`background-color:${aptColor}20;color:${aptColor};box-shadow:inset 0 0 0 1px ${aptColor}40`}>
                        {aptName}
                      </span>
                      {aptUsers.length > 0 && (
                        <select
                          class="input py-1 text-xs flex-1 min-w-0"
                          onchange={`assignCleaning('${r.id}', '${r.check_out}', this.value)`}
                        >
                          <option value="">— Čišćenje —</option>
                          {aptUsers.map((u) => (
                            <option value={u.user_id} selected={cleaner?.user_id === u.user_id}>
                              {u.full_name}
                            </option>
                          ))}
                        </select>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
            {/* Desktop table */}
            <div class="hidden md:block overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr>
                    <th class="table-head px-4 py-3 text-left">Gost</th>
                    <th class="table-head px-4 py-3 text-left">Apartman</th>
                    <th class="table-head px-4 py-3 text-center">Noćenja</th>
                    <th class="table-head px-4 py-3 text-left">Čišćenje</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {checkoutsToday.map((r) => {
                    const cleaner = cleaningMap.get(r.id);
                    const aptUsers = aptUsersForCleaningMap[r.apartment_id] ?? [];
                    const aptColor = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
                    const aptName  = aptNameMap.get(r.apartment_id) ?? '—';
                    return (
                      <tr class="table-row">
                        <td class="table-cell font-medium text-gray-900">{r.guest_name}</td>
                        <td class="table-cell">
                          <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium whitespace-nowrap"
                            style={`background-color:${aptColor}20;color:${aptColor};box-shadow:inset 0 0 0 1px ${aptColor}40`}>
                            {aptName}
                          </span>
                        </td>
                        <td class="table-cell text-center text-gray-700 font-medium">{nights(r.check_in, r.check_out)}</td>
                        <td class="table-cell">
                          <div class="flex flex-col gap-1">
                            {aptUsers.length > 0 && (
                              <select
                                class="input py-1 text-xs w-40"
                                onchange={`assignCleaning('${r.id}', '${r.check_out}', this.value)`}
                              >
                                <option value="">— Odaberi —</option>
                                {aptUsers.map((u) => (
                                  <option value={u.user_id} selected={cleaner?.user_id === u.user_id}>
                                    {u.full_name}
                                  </option>
                                ))}
                              </select>
                            )}
                            {cleaner && (
                              <span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10 w-fit">
                                {cleaner.full_name}
                              </span>
                            )}
                            {aptUsers.length === 0 && <span class="text-gray-400 text-xs">—</span>}
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </>
        )}
      </div>

      <!-- Check-in danas -->
      <div class="card">
        <div class="px-4 md:px-5 py-3 md:py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-900">Check-in danas</h2>
          <p class="text-xs text-gray-400 mt-0.5">{formatDate(todayStr)}</p>
        </div>
        {!checkinsToday?.length ? (
          <div class="p-8 text-center text-gray-400 text-sm">Nema check-inova danas.</div>
        ) : (
          <>
            {/* Mobile card layout */}
            <div class="md:hidden divide-y divide-gray-100">
              {checkinsToday.map((r) => {
                const cleaner = cleaningMap.get(r.id);
                const aptUsers = aptUsersForCleaningMap[r.apartment_id] ?? [];
                const aptColor = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
                const aptName  = aptNameMap.get(r.apartment_id) ?? '—';
                return (
                  <div class="px-4 py-3">
                    <div class="flex items-center justify-between gap-2 mb-1.5">
                      <span class="font-medium text-gray-900 text-sm truncate">{r.guest_name}</span>
                      <span class="text-xs text-gray-500 flex-shrink-0">{nights(r.check_in, r.check_out)} noć.</span>
                    </div>
                    <div class="flex items-center gap-2 flex-wrap">
                      <span class="inline-flex items-center rounded-md px-2 py-0.5 text-xs font-medium whitespace-nowrap"
                        style={`background-color:${aptColor}20;color:${aptColor};box-shadow:inset 0 0 0 1px ${aptColor}40`}>
                        {aptName}
                      </span>
                      {aptUsers.length > 0 && (
                        <select
                          class="input py-1 text-xs flex-1 min-w-0"
                          onchange={`assignCleaning('${r.id}', '${r.check_out}', this.value)`}
                        >
                          <option value="">— Čišćenje —</option>
                          {aptUsers.map((u) => (
                            <option value={u.user_id} selected={cleaner?.user_id === u.user_id}>
                              {u.full_name}
                            </option>
                          ))}
                        </select>
                      )}
                    </div>
                  </div>
                );
              })}
            </div>
            {/* Desktop table */}
            <div class="hidden md:block overflow-x-auto">
              <table class="w-full text-sm">
                <thead>
                  <tr>
                    <th class="table-head px-4 py-3 text-left">Gost</th>
                    <th class="table-head px-4 py-3 text-left">Apartman</th>
                    <th class="table-head px-4 py-3 text-center">Noćenja</th>
                    <th class="table-head px-4 py-3 text-left">Čišćenje</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {checkinsToday.map((r) => {
                    const cleaner = cleaningMap.get(r.id);
                    const aptUsers = aptUsersForCleaningMap[r.apartment_id] ?? [];
                    const aptColor = aptColorMap.get(r.apartment_id) ?? '#3B82F6';
                    const aptName  = aptNameMap.get(r.apartment_id) ?? '—';
                    return (
                      <tr class="table-row">
                        <td class="table-cell font-medium text-gray-900">{r.guest_name}</td>
                        <td class="table-cell">
                          <span class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium whitespace-nowrap"
                            style={`background-color:${aptColor}20;color:${aptColor};box-shadow:inset 0 0 0 1px ${aptColor}40`}>
                            {aptName}
                          </span>
                        </td>
                        <td class="table-cell text-center text-gray-700 font-medium">{nights(r.check_in, r.check_out)}</td>
                        <td class="table-cell">
                          <div class="flex flex-col gap-1">
                            {aptUsers.length > 0 && (
                              <select
                                class="input py-1 text-xs w-40"
                                onchange={`assignCleaning('${r.id}', '${r.check_out}', this.value)`}
                              >
                                <option value="">— Odaberi —</option>
                                {aptUsers.map((u) => (
                                  <option value={u.user_id} selected={cleaner?.user_id === u.user_id}>
                                    {u.full_name}
                                  </option>
                                ))}
                              </select>
                            )}
                            {cleaner && (
                              <span class="inline-flex items-center rounded-md bg-purple-50 px-2 py-0.5 text-xs font-medium text-purple-700 ring-1 ring-inset ring-purple-700/10 w-fit">
                                {cleaner.full_name}
                              </span>
                            )}
                            {aptUsers.length === 0 && <span class="text-gray-400 text-xs">—</span>}
                          </div>
                        </td>
                      </tr>
                    );
                  })}
                </tbody>
              </table>
            </div>
          </>
        )}
      </div>

    </div>{/* end grid check-in/out */}

    <!-- Grafovi: Prihodi i Čišćenje -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-4 md:gap-6 mt-4 md:mt-6">

      <!-- Graf: Prihodi po načinu plaćanja -->
      <div class="card">
        <div class="px-4 md:px-5 py-3 md:py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-900">Prihodi po načinu plaćanja</h2>
          <p class="text-xs text-gray-400 mt-0.5">Raspodjela bruto prihoda</p>
        </div>
        <div class="p-4 md:p-5">
          {prihodiValues.length === 0 ? (
            <div class="flex items-center justify-center h-48 text-gray-400 text-sm">Nema podataka za odabrani period.</div>
          ) : (
            <div class="relative h-64">
              <canvas
                id="chart-prihodi"
                data-labels={JSON.stringify(prihodiLabels)}
                data-values={JSON.stringify(prihodiValues)}
                data-colors={JSON.stringify(prihodiColors)}
              ></canvas>
            </div>
          )}
        </div>
      </div>

      <!-- Graf: Čišćenja po osobi -->
      <div class="card">
        <div class="px-4 md:px-5 py-3 md:py-4 border-b border-gray-100">
          <h2 class="font-semibold text-gray-900">Čišćenja po osobi</h2>
          <p class="text-xs text-gray-400 mt-0.5">Ukupan broj dodijeljenih čišćenja</p>
        </div>
        <div class="p-4 md:p-5">
          {cleaningValues.length === 0 ? (
            <div class="flex items-center justify-center h-48 text-gray-400 text-sm">Nema podataka o čišćenjima.</div>
          ) : (
            <div class="relative h-64">
              <canvas
                id="chart-ciscenje"
                data-labels={JSON.stringify(cleaningLabels)}
                data-values={JSON.stringify(cleaningValues)}
              ></canvas>
            </div>
          )}
        </div>
      </div>

    </div>{/* end grid grafovi */}

  </div>

  <div id="toast" class="hidden fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg"></div>
</AppLayout>

<script>
  function showToast(message: string, type: 'success' | 'error' = 'success') {
    const toast = document.getElementById('toast');
    if (!toast) return;
    toast.textContent = message;
    toast.className = `fixed bottom-4 right-4 z-50 rounded-lg px-4 py-3 text-sm font-medium shadow-lg ${
      type === 'success' ? 'bg-green-600 text-white' : 'bg-red-600 text-white'
    }`;
    toast.classList.remove('hidden');
    setTimeout(() => toast.classList.add('hidden'), 3000);
  }

  async function assignCleaning(reservationId: string, checkOut: string, userId: string) {
    try {
      const res = await fetch('/api/rezervacije/assign-cleaning', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ reservation_id: reservationId, user_id: userId || null, check_out: checkOut }),
      });
      const data = await res.json();
      if (res.ok) {
        showToast('Čišćenje dodijeljeno.');
      } else {
        showToast(data.error ?? 'Greška pri dodjeli čišćenja.', 'error');
      }
    } catch {
      showToast('Greška pri slanju zahtjeva.', 'error');
    }
  }

  (window as any).assignCleaning = assignCleaning;
</script>

<script>
  import Chart from 'chart.js/auto';

  // Graf: Prihodi po načinu plaćanja (doughnut)
  const prihodiCanvas = document.getElementById('chart-prihodi') as HTMLCanvasElement | null;
  if (prihodiCanvas) {
    const labels: string[] = JSON.parse(prihodiCanvas.dataset.labels ?? '[]');
    const values: number[] = JSON.parse(prihodiCanvas.dataset.values ?? '[]');
    const colors: string[] = JSON.parse(prihodiCanvas.dataset.colors ?? '[]');
    new Chart(prihodiCanvas, {
      type: 'doughnut',
      data: {
        labels,
        datasets: [{
          data: values,
          backgroundColor: colors,
          borderWidth: 2,
          borderColor: '#fff',
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        plugins: {
          legend: {
            position: 'bottom',
            labels: { padding: 16, font: { size: 12 } },
          },
          tooltip: {
            callbacks: {
              label: (ctx) => {
                const val = ctx.parsed as number;
                return ` ${ctx.label}: €${val.toFixed(2)}`;
              },
            },
          },
        },
      },
    });
  }

  // Graf: Čišćenja po osobi (horizontalni bar)
  const ciscenjeCanvas = document.getElementById('chart-ciscenje') as HTMLCanvasElement | null;
  if (ciscenjeCanvas) {
    const labels: string[] = JSON.parse(ciscenjeCanvas.dataset.labels ?? '[]');
    const values: number[] = JSON.parse(ciscenjeCanvas.dataset.values ?? '[]');
    new Chart(ciscenjeCanvas, {
      type: 'bar',
      data: {
        labels,
        datasets: [{
          label: 'Čišćenja',
          data: values,
          backgroundColor: '#6366F1',
          borderRadius: 6,
        }],
      },
      options: {
        responsive: true,
        maintainAspectRatio: false,
        indexAxis: 'y',
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: {
              label: (ctx) => ` ${ctx.parsed.x} čišćenja`,
            },
          },
        },
        scales: {
          x: {
            beginAtZero: true,
            ticks: { stepSize: 1 },
            grid: { color: '#f3f4f6' },
          },
          y: {
            grid: { display: false },
          },
        },
      },
    });
  }
</script>
