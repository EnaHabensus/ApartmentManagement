---
import AppLayout from '../layouts/AppLayout.astro';
import { createSupabaseServerClient, createSupabaseAdminClient } from '../lib/supabase';

const supabase = createSupabaseServerClient(Astro.request, Astro.cookies);
const { data: { user } } = await supabase.auth.getUser();
if (!user) return Astro.redirect('/login');

const profile = Astro.locals.user!;
const adminSupabase = createSupabaseAdminClient();

const { data: myApartmentUsers } = await adminSupabase
  .from('apartment_users')
  .select('apartment_id, role')
  .eq('user_id', user.id);

const isAdmin = (myApartmentUsers ?? []).some((au) => au.role === 'admin');
const allApartmentIds = (myApartmentUsers ?? []).map((au) => au.apartment_id);

if (allApartmentIds.length === 0) return Astro.redirect('/');

const filterApartmentId = Astro.url.searchParams.get('apartment_id') ?? '';

const { data: apartmentsData } = await adminSupabase
  .from('apartments')
  .select('id, name, color')
  .in('id', allApartmentIds)
  .eq('is_deleted', false);

const allApartments = apartmentsData ?? [];
const aptColorMap = Object.fromEntries(allApartments.map((a) => [a.id, { name: a.name, color: (a as any).color ?? '#3B82F6' }]));

const aptIds = filterApartmentId ? [filterApartmentId] : allApartmentIds;

const { data: allCalRez } = await adminSupabase
  .from('reservations')
  .select('id, guest_name, check_in, check_out, apartment_id')
  .in('apartment_id', aptIds.length > 0 ? aptIds : ['none'])
  .eq('status', 'active');

const calendarData = (allCalRez ?? []).map((r) => ({
  id: r.id,
  guest: r.guest_name,
  check_in: r.check_in,
  check_out: r.check_out,
  aptName: aptColorMap[r.apartment_id]?.name ?? '',
  color: aptColorMap[r.apartment_id]?.color ?? '#3B82F6',
}));
---

<AppLayout title="Kalendar" user={profile} isAdmin={isAdmin} activeRoute="/kalendar">
  <div class="p-6 max-w-7xl mx-auto">

    <!-- Header -->
    <div class="flex items-center justify-between mb-6">
      <div>
        <h1 class="text-2xl font-bold text-gray-900">Kalendar</h1>
        <p class="text-gray-500 text-sm mt-1">Pregled rezervacija po datumu</p>
      </div>
      <form method="GET" action="/kalendar" id="filter-form">
        <select
          name="apartment_id"
          onchange="document.getElementById('filter-form').submit()"
          class="input py-1.5 text-sm w-auto"
        >
          <option value="">Svi apartmani</option>
          {allApartments.map((apt) => (
            <option value={apt.id} selected={filterApartmentId === apt.id}>{apt.name}</option>
          ))}
        </select>
      </form>
    </div>

    <!-- Legenda apartmana -->
    {allApartments.length > 1 && (
      <div class="flex flex-wrap gap-2 mb-4">
        {allApartments.map((apt) => {
          const color = (apt as any).color ?? '#3B82F6';
          return (
            <span
              class="inline-flex items-center rounded-md px-2 py-1 text-xs font-medium"
              style={`background-color: ${color}20; color: ${color}; box-shadow: inset 0 0 0 1px ${color}40`}
            >
              {apt.name}
            </span>
          );
        })}
      </div>
    )}

    <!-- Kalendar -->
    <div class="card">
      <div class="flex items-center justify-between px-5 py-4 border-b border-gray-100">
        <button id="cal-prev" class="btn-ghost px-3 py-1.5 text-gray-600 hover:text-gray-900">← Prethodni</button>
        <span id="cal-title" class="text-base font-semibold text-gray-800 min-w-[160px] text-center"></span>
        <button id="cal-next" class="btn-ghost px-3 py-1.5 text-gray-600 hover:text-gray-900">Sljedeći →</button>
      </div>
      <div class="p-4">
        <div id="cal-grid"></div>
      </div>
    </div>

  </div>
</AppLayout>

<script define:vars={{ calendarData }}>
  const DAYS = ['Pon', 'Uto', 'Sri', 'Čet', 'Pet', 'Sub', 'Ned'];
  const MONTHS = ['Siječanj','Veljača','Ožujak','Travanj','Svibanj','Lipanj','Srpanj','Kolovoz','Rujan','Listopad','Studeni','Prosinac'];

  let calYear = new Date().getFullYear();
  let calMonth = new Date().getMonth();

  function toDate(s) { return new Date(s + 'T00:00:00'); }

  function renderCalendar() {
    const today = new Date(); today.setHours(0,0,0,0);
    document.getElementById('cal-title').textContent = `${MONTHS[calMonth]} ${calYear}`;

    const firstDay = new Date(calYear, calMonth, 1);
    const lastDay = new Date(calYear, calMonth + 1, 0);
    let startOffset = (firstDay.getDay() + 6) % 7;
    const totalCells = startOffset + lastDay.getDate();
    const rows = Math.ceil(totalCells / 7);

    let html = `<div class="grid grid-cols-7 gap-px bg-gray-200 rounded-lg overflow-hidden">`;

    for (const d of DAYS) {
      html += `<div class="bg-gray-50 text-center text-xs font-semibold text-gray-500 py-2">${d}</div>`;
    }

    for (let i = 0; i < rows * 7; i++) {
      const dayNum = i - startOffset + 1;
      const isValid = dayNum >= 1 && dayNum <= lastDay.getDate();
      const dateStr = isValid ? `${calYear}-${String(calMonth+1).padStart(2,'0')}-${String(dayNum).padStart(2,'0')}` : '';
      const isToday = isValid && new Date(calYear, calMonth, dayNum).getTime() === today.getTime();

      if (!isValid) {
        html += `<div class="bg-gray-50 min-h-[90px] p-1"></div>`;
        continue;
      }

      const dayRez = calendarData.filter(r => {
        const ci = toDate(r.check_in), co = toDate(r.check_out);
        const d = new Date(calYear, calMonth, dayNum);
        return ci <= d && co > d;
      });

      const isCheckIn = (r) => r.check_in === dateStr;
      const isCheckOut = (r) => r.check_out === dateStr;

      html += `<div class="bg-white min-h-[90px] p-1 ${isToday ? 'ring-2 ring-inset ring-blue-500' : ''}">`;
      html += `<div class="text-xs font-medium mb-1 ${isToday ? 'text-blue-600' : 'text-gray-700'}">${dayNum}</div>`;

      for (const r of dayRez) {
        const color = r.color || '#3B82F6';
        const cin = isCheckIn(r), cout = isCheckOut(r);
        const label = cin ? `✈ ${r.guest}` : cout ? `⬜ ${r.guest}` : `· ${r.guest}`;
        const borderRadius = cin && cout ? 'border-radius:4px' : cin ? 'border-radius:4px 0 0 4px' : cout ? 'border-radius:0 4px 4px 0' : 'border-radius:0';
        html += `<div class="text-xs px-1 py-0.5 mb-0.5 truncate" style="background:${color}25;color:${color};${borderRadius}" title="${r.guest} | ${r.aptName} | ${r.check_in} → ${r.check_out}">${label}</div>`;
      }

      html += `</div>`;
    }

    html += `</div>`;
    document.getElementById('cal-grid').innerHTML = html;
  }

  document.getElementById('cal-prev').addEventListener('click', () => {
    calMonth--; if (calMonth < 0) { calMonth = 11; calYear--; }
    renderCalendar();
  });
  document.getElementById('cal-next').addEventListener('click', () => {
    calMonth++; if (calMonth > 11) { calMonth = 0; calYear++; }
    renderCalendar();
  });

  renderCalendar();
</script>
