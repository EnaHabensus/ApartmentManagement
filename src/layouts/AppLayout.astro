---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro';
import type { Profile } from '../lib/types';
import { createSupabaseAdminClient } from '../lib/supabase';

interface Props {
  title: string;
  user: Profile;
  isAdmin: boolean;
  activeRoute?: string;
}

const { title, user, isAdmin, activeRoute = '' } = Astro.props;

const adminSupabase = createSupabaseAdminClient();
let unreadCount = 0;
try {
  const { count } = await adminSupabase
    .from('notifications')
    .select('id', { count: 'exact', head: true })
    .eq('user_id', user.id)
    .eq('is_read', false);
  unreadCount = count ?? 0;
} catch { /* tablica još ne postoji */ }
---

<!DOCTYPE html>
<html lang="hr">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} — Moji Apartmani</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="flex h-screen overflow-hidden bg-slate-50">

    <!-- Mobile overlay -->
    <div id="sidebar-overlay" class="fixed inset-0 z-30 bg-black/40 hidden md:hidden"></div>

    <!-- Sidebar wrapper — fixed overlay on mobile, static on desktop -->
    <div
      id="sidebar-wrap"
      class="fixed inset-y-0 left-0 z-40 -translate-x-full transition-transform duration-200 ease-in-out md:relative md:translate-x-0 md:flex-shrink-0"
    >
      <Sidebar user={user} isAdmin={isAdmin} activeRoute={activeRoute} />
    </div>

    <!-- Desni dio: header + sadržaj -->
    <div class="flex-1 flex flex-col min-h-0 overflow-hidden">

      <!-- Top bar -->
      <header class="flex h-14 items-center px-4 md:px-6 bg-white border-b border-slate-200 flex-shrink-0 z-20 gap-3">
        <!-- Hamburger — samo mobile -->
        <button
          id="hamburger-btn"
          class="md:hidden p-2 rounded-lg text-slate-500 hover:text-slate-700 hover:bg-slate-100 transition-colors -ml-1 flex-shrink-0"
          aria-label="Otvori meni"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="4" y1="6" x2="20" y2="6"/>
            <line x1="4" y1="12" x2="20" y2="12"/>
            <line x1="4" y1="18" x2="20" y2="18"/>
          </svg>
        </button>

        <div class="flex-1"></div>

        <!-- Notification bell -->
        <div class="relative" id="notif-wrap">
          <button
            id="notif-btn"
            class="relative p-2 rounded-lg text-slate-500 hover:text-slate-700 hover:bg-slate-100 transition-colors"
            aria-label="Notifikacije"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M6 8a6 6 0 0 1 12 0c0 7 3 9 3 9H3s3-2 3-9"/>
              <path d="M10.3 21a1.94 1.94 0 0 0 3.4 0"/>
            </svg>
            {(unreadCount ?? 0) > 0 && (
              <span
                id="notif-badge"
                class="absolute -top-0.5 -right-0.5 h-4 w-4 rounded-full bg-red-500 text-white text-[10px] font-bold flex items-center justify-center"
              >
                {(unreadCount ?? 0) > 9 ? '9+' : unreadCount}
              </span>
            )}
          </button>

          <!-- Dropdown -->
          <div
            id="notif-dropdown"
            class="hidden absolute right-0 top-full mt-2 w-80 rounded-xl border border-slate-200 bg-white shadow-xl z-50 overflow-hidden"
          >
            <div class="flex items-center justify-between px-4 py-3 border-b border-slate-100">
              <h3 class="text-sm font-semibold text-slate-900">Notifikacije</h3>
              <button id="notif-mark-read" class="text-xs text-blue-600 hover:text-blue-700 font-medium">
                Označi sve kao pročitano
              </button>
            </div>
            <div id="notif-list" class="max-h-[420px] overflow-y-auto divide-y divide-slate-50">
              <p class="px-4 py-6 text-sm text-slate-400 text-center">Učitavanje...</p>
            </div>
          </div>
        </div>
      </header>

      <!-- Glavni sadržaj -->
      <main class="flex-1 overflow-y-auto">
        <slot />
      </main>
    </div>
  </body>
</html>

<script>
  // ── Sidebar mobile ────────────────────────────────────────────────────────────

  const hamburger = document.getElementById('hamburger-btn');
  const sidebarWrap = document.getElementById('sidebar-wrap');
  const overlay = document.getElementById('sidebar-overlay');

  function openSidebar() {
    sidebarWrap?.classList.remove('-translate-x-full');
    overlay?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeSidebar() {
    sidebarWrap?.classList.add('-translate-x-full');
    overlay?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  hamburger?.addEventListener('click', openSidebar);
  overlay?.addEventListener('click', closeSidebar);

  // Zatvori sidebar klikom na link unutar njega (mobile nav)
  sidebarWrap?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 768) closeSidebar();
    });
  });

  // ── Notifikacije ──────────────────────────────────────────────────────────────

  function relativeTime(dateStr: string): string {
    const diff = Date.now() - new Date(dateStr).getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return 'Upravo';
    if (mins < 60) return `${mins} min`;
    const hrs = Math.floor(mins / 60);
    if (hrs < 24) return `${hrs} h`;
    const days = Math.floor(hrs / 24);
    if (days === 1) return 'Jučer';
    return `${days} dana`;
  }

  const TYPE_COLOR: Record<string, string> = {
    task_assigned:     'bg-blue-100 text-blue-600',
    task_completed:    'bg-green-100 text-green-600',
    task_cancelled:    'bg-red-100 text-red-500',
    cleaning_assigned: 'bg-blue-100 text-blue-600',
    cleaning_cancelled:'bg-red-100 text-red-500',
    invite_accepted:   'bg-green-100 text-green-600',
    invite_declined:   'bg-red-100 text-red-500',
  };

  const TYPE_ICON: Record<string, string> = {
    task_assigned:     `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`,
    task_completed:    `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="9 12 11 14 15 10"/></svg>`,
    task_cancelled:    `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
    cleaning_assigned: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275Z"/></svg>`,
    cleaning_cancelled:`<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
    invite_accepted:   `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><polyline points="16 11 18 13 22 9"/></svg>`,
    invite_declined:   `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><line x1="17" y1="11" x2="22" y2="16"/><line x1="22" y1="11" x2="17" y2="16"/></svg>`,
  };

  function renderNotifItem(n: any): string {
    const color = TYPE_COLOR[n.type] ?? 'bg-slate-100 text-slate-500';
    const icon = TYPE_ICON[n.type] ?? '';
    const time = relativeTime(n.created_at);
    const bg = !n.is_read ? 'bg-blue-50/40' : '';
    const onclick = n.link ? `window.location.href='${n.link}'` : '';
    return `
      <div class="flex gap-3 px-4 py-3 hover:bg-slate-50 ${bg} transition-colors ${n.link ? 'cursor-pointer' : ''}"
           ${n.link ? `onclick="${onclick}"` : ''}>
        <div class="flex-shrink-0 h-8 w-8 rounded-full ${color} flex items-center justify-center">${icon}</div>
        <div class="flex-1 min-w-0">
          <p class="text-sm font-semibold text-slate-900 leading-tight">${n.title}</p>
          ${n.body ? `<p class="text-xs text-slate-500 mt-0.5 leading-relaxed">${n.body}</p>` : ''}
          <p class="text-xs text-slate-400 mt-1">${time}</p>
        </div>
        ${!n.is_read ? '<div class="flex-shrink-0 h-2 w-2 rounded-full bg-blue-500 mt-1.5"></div>' : '<div class="w-2"></div>'}
      </div>`;
  }

  let notifLoaded = false;
  const notifBtn = document.getElementById('notif-btn')!;
  const notifDropdown = document.getElementById('notif-dropdown')!;

  async function openNotifDropdown() {
    const list = document.getElementById('notif-list')!;
    const badge = document.getElementById('notif-badge');

    if (!notifLoaded) {
      notifLoaded = true;
      try {
        const res = await fetch('/api/notifikacije');
        const data = await res.json();
        const notifs: any[] = data.notifications ?? [];
        list.innerHTML = notifs.length === 0
          ? '<p class="px-4 py-8 text-sm text-slate-400 text-center">Nema notifikacija.</p>'
          : notifs.map(renderNotifItem).join('');
      } catch {
        list.innerHTML = '<p class="px-4 py-6 text-sm text-red-500 text-center">Greška pri učitavanju.</p>';
      }
    }

    if (badge) {
      fetch('/api/notifikacije/mark-read', { method: 'POST' }).catch(() => {});
      badge.remove();
    }
  }

  notifBtn.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = notifDropdown.classList.contains('hidden');
    notifDropdown.classList.toggle('hidden');
    if (isHidden) openNotifDropdown();
  });

  document.addEventListener('click', (e) => {
    if (!document.getElementById('notif-wrap')?.contains(e.target as Node)) {
      notifDropdown.classList.add('hidden');
    }
  });

  document.getElementById('notif-mark-read')?.addEventListener('click', async () => {
    await fetch('/api/notifikacije/mark-read', { method: 'POST' });
    document.getElementById('notif-badge')?.remove();
    document.querySelectorAll('#notif-list .bg-blue-500.rounded-full').forEach((el) => el.classList.add('invisible'));
  });
</script>
