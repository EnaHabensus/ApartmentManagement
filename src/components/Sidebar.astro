---
import type { Profile } from '../lib/types';

interface Props {
  user: Profile;
  isAdmin: boolean;
  activeRoute: string;
}

const { user, isAdmin, activeRoute } = Astro.props;

const adminNav = [
  { href: '/', label: 'Dashboard', icon: 'bar-chart-2' },
  { href: '/rezervacije', label: 'Rezervacije', icon: 'calendar-days' },
  { href: '/kalendar', label: 'Kalendar', icon: 'calendar' },
  { href: '/financije', label: 'Financije', icon: 'wallet' },
  { href: '/racuni', label: 'Računi', icon: 'file-text' },
  { href: '/apartmani', label: 'Apartmani', icon: 'building-2' },
  { href: '/troskovi', label: 'Troškovi', icon: 'receipt' },
  { href: '/korisnici', label: 'Korisnici', icon: 'users' },
  { href: '/zadatci', label: 'Zadatci', icon: 'check-square' },
];

const staffNav = [
  { href: '/zadatci', label: 'Zadatci', icon: 'check-square' },
];

const nav = isAdmin ? adminNav : staffNav;

function isActive(href: string): boolean {
  if (href === '/') return activeRoute === '/';
  return activeRoute.startsWith(href);
}

const initials = user.full_name
  .split(' ')
  .map((n) => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();
---

<aside class="flex h-screen w-64 flex-col border-r border-gray-200 bg-white">
  <!-- Logo -->
  <div class="flex h-16 items-center px-6 border-b border-gray-100">
    <div class="flex items-center gap-2">
      <div class="h-8 w-8 rounded-lg bg-blue-600 flex items-center justify-center">
        <span class="text-white font-bold text-sm">A</span>
      </div>
      <span class="text-lg font-bold text-gray-900">Moji Apartmani</span>
    </div>
  </div>

  <!-- Navigacija -->
  <nav class="flex-1 overflow-y-auto px-3 py-4 space-y-1">
    {nav.map(({ href, label }) => (
      <a
        href={href}
        class={isActive(href) ? 'sidebar-link-active' : 'sidebar-link'}
      >
        <span>{label}</span>
      </a>
    ))}
  </nav>

  <!-- Korisnik i odjava -->
  <div class="border-t border-gray-100 p-3">
    <div class="flex items-center gap-3 rounded-lg p-2">
      <div class="h-8 w-8 rounded-full bg-blue-100 flex items-center justify-center flex-shrink-0">
        <span class="text-blue-700 font-semibold text-xs">{initials}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-sm font-medium text-gray-900 truncate">{user.full_name}</p>
        <p class="text-xs text-gray-500 truncate">{user.email}</p>
      </div>
    </div>
    <form action="/api/auth/logout" method="POST" class="mt-1">
      <button
        type="submit"
        class="w-full text-left sidebar-link text-red-600 hover:bg-red-50 hover:text-red-700"
      >
        Odjava
      </button>
    </form>
  </div>
</aside>
