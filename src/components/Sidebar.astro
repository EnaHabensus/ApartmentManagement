---
import type { Profile } from '../lib/types';

interface Props {
  user: Profile;
  isAdmin: boolean;
  activeRoute: string;
}

const { user, isAdmin, activeRoute } = Astro.props;

const adminNav = [
  { href: '/',           label: 'Dashboard',  icon: 'chart' },
  { href: '/rezervacije',label: 'Rezervacije',icon: 'calendar-days' },
  { href: '/kalendar',   label: 'Kalendar',   icon: 'calendar' },
  { href: '/financije',  label: 'Financije',  icon: 'wallet' },
  { href: '/racuni',     label: 'Računi',     icon: 'file-text' },
  { href: '/apartmani',  label: 'Apartmani',  icon: 'building' },
  { href: '/troskovi',   label: 'Troškovi',   icon: 'receipt' },
  { href: '/korisnici',  label: 'Korisnici',  icon: 'users' },
  { href: '/zadatci',    label: 'Zadatci',    icon: 'check-square' },
];

const staffNav = [
  { href: '/zadatci', label: 'Zadatci', icon: 'check-square' },
];

const nav = isAdmin ? adminNav : staffNav;

function isActive(href: string): boolean {
  if (href === '/') return activeRoute === '/';
  return activeRoute.startsWith(href);
}

const initials = user.full_name
  .split(' ')
  .map((n) => n[0])
  .slice(0, 2)
  .join('')
  .toUpperCase();

// Inline SVG icons (Lucide-style, 16×16 stroke)
const icons: Record<string, string> = {
  chart: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="20" x2="18" y2="10"/><line x1="12" y1="20" x2="12" y2="4"/><line x1="6" y1="20" x2="6" y2="14"/></svg>`,
  'calendar-days': `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="14" x2="8" y2="14"/><line x1="12" y1="14" x2="12" y2="14"/><line x1="16" y1="14" x2="16" y2="14"/><line x1="8" y1="18" x2="8" y2="18"/><line x1="12" y1="18" x2="12" y2="18"/></svg>`,
  calendar: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>`,
  wallet: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20 12V22H4a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h16v4"/><path d="M20 12a2 2 0 0 0-2 2 2 2 0 0 0 2 2h4v-4Z"/><circle cx="20" cy="14" r=".5" fill="currentColor"/></svg>`,
  'file-text': `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8Z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><line x1="10" y1="9" x2="8" y2="9"/></svg>`,
  building: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 22V4a2 2 0 0 1 2-2h8a2 2 0 0 1 2 2v18Z"/><path d="M6 12H4a2 2 0 0 0-2 2v8h4"/><path d="M18 9h2a2 2 0 0 1 2 2v11h-4"/><path d="M10 6h4"/><path d="M10 10h4"/><path d="M10 14h4"/><path d="M10 18h4"/></svg>`,
  receipt: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 2v20l2-1 2 1 2-1 2 1 2-1 2 1 2-1 2 1V2l-2 1-2-1-2 1-2-1-2 1-2-1-2 1Z"/><line x1="8" y1="10" x2="16" y2="10"/><line x1="8" y1="14" x2="16" y2="14"/><line x1="8" y1="6" x2="12" y2="6"/></svg>`,
  users: `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  'check-square': `<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 11 12 14 22 4"/><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg>`,
  logout: `<svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/><polyline points="16 17 21 12 16 7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>`,
};
---

<aside class="flex h-screen w-60 flex-col bg-white border-r border-slate-200">
  <!-- Logo -->
  <div class="flex h-14 items-center px-5 border-b border-slate-100">
    <div class="flex items-center gap-2.5">
      <div class="h-7 w-7 rounded-lg bg-blue-600 flex items-center justify-center flex-shrink-0">
        <span class="text-white font-bold text-xs tracking-tight">MA</span>
      </div>
      <span class="text-sm font-semibold text-slate-900 tracking-tight">Moji Apartmani</span>
    </div>
  </div>

  <!-- Navigacija -->
  <nav class="flex-1 overflow-y-auto px-3 py-3 space-y-0.5">
    {nav.map(({ href, label, icon }) => (
      <a href={href} class={isActive(href) ? 'sidebar-link-active' : 'sidebar-link'}>
        <span class="shrink-0" set:html={icons[icon] ?? ''} />
        <span>{label}</span>
      </a>
    ))}
  </nav>

  <!-- Korisnik i odjava -->
  <div class="border-t border-slate-100 p-3 space-y-0.5">
    <div class="flex items-center gap-2.5 px-3 py-2 rounded-md">
      <div class="h-7 w-7 rounded-full bg-blue-600 flex items-center justify-center flex-shrink-0">
        <span class="text-white font-semibold text-xs">{initials}</span>
      </div>
      <div class="flex-1 min-w-0">
        <p class="text-xs font-semibold text-slate-900 truncate">{user.full_name}</p>
        <p class="text-xs text-slate-400 truncate">{user.email}</p>
      </div>
    </div>
    <form action="/api/auth/logout" method="POST">
      <button
        type="submit"
        class="sidebar-link w-full text-slate-500 hover:bg-red-50 hover:text-red-600"
      >
        <span class="shrink-0" set:html={icons.logout} />
        <span>Odjava</span>
      </button>
    </form>
  </div>
</aside>
